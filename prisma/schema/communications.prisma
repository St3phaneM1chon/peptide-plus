model ChatConversation {
  id              String        @id @default(cuid())
  tenantId        String?
  visitorId       String
  visitorName     String?
  visitorEmail    String?
  visitorLanguage String        @default("en")
  userId          String?
  status          ChatStatus    @default(ACTIVE)
  isOnline        Boolean       @default(true)
  userAgent       String?
  ipCountry       String?
  currentPage     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  lastMessageAt   DateTime      @default(now())
  closedAt        DateTime?
  messages        ChatMessage[]

  @@index([lastMessageAt])
  @@index([status])
  @@index([userId])
  @@index([visitorId])
  // FIX F-037: Composite index for the common query pattern: findFirst where visitorId + status
  @@index([visitorId, status])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

model ChatMessage {
  id              String           @id @default(cuid())
  tenantId        String?
  conversationId  String
  content         String
  contentOriginal String?
  sender          ChatSender
  senderName      String?
  language        String           @default("en")
  translatedTo    String?
  isRead          Boolean          @default(false)
  readAt          DateTime?
  isFromBot       Boolean          @default(false)
  metadata        String?
  type            ChatMessageType  @default(TEXT)
  attachmentUrl   String?
  attachmentName  String?
  attachmentSize  Int?
  createdAt       DateTime         @default(now())
  conversation    ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@index([tenantId])
}

model ChatSettings {
  id                 String   @id @default("default")
  tenantId           String?
  isAdminOnline      Boolean  @default(false)
  adminLanguage      String   @default("fr")
  chatbotEnabled     Boolean  @default(true)
  chatbotGreeting    String?
  chatbotPrompt      String?
  notifyEmail        String?
  notifyOnNewChat    Boolean  @default(true)
  notifyOnEscalation Boolean  @default(true)
  widgetColor        String   @default("#f97316")
  widgetPosition     String   @default("bottom-right")
  updatedAt          DateTime @updatedAt
  @@index([updatedAt])
  @@index([tenantId])
}

model Conversation {
  id            String             @id @default(cuid())
  tenantId      String?
  userId        String
  subject       String?
  status        ConversationStatus @default(OPEN)
  assignedToId  String?
  priority      Int                @default(0)
  tags          String?
  lastMessageAt DateTime           @default(now())
  unreadCount   Int                @default(1)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  assignedTo    User?              @relation("Conversation_assignedToIdToUser", fields: [assignedToId], references: [id], onDelete: SetNull)
  // FIX A1-P0-005: Preserve conversation history when user is deleted
  user          User               @relation("Conversation_userIdToUser", fields: [userId], references: [id], onDelete: Restrict)
  messages      Message[]

  @@index([assignedToId])
  @@index([assignedToId, status]) // Agent queue: find open conversations for an agent
  @@index([lastMessageAt])
  @@index([status])
  @@index([userId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

model EmailLog {
  id         String    @id @default(cuid())
  tenantId   String?
  templateId String?
  to         String
  subject    String
  status     String    @default("sent")
  error      String?
  messageId  String?
  sentAt     DateTime  @default(now())
  openedAt   DateTime?
  clickedAt  DateTime?
  clickCount Int       @default(0)
  // A/B test variant tracking: "A" or "B" (null = not an A/B test)
  abVariant  String?
  // Bridge: FK to User for efficient cross-module queries
  userId     String?
  user       User?     @relation("UserEmailLogs", fields: [userId], references: [id], onDelete: SetNull)
  // Bridge #33/#44: FK to EmailCampaign for Marketing↔Email bridges
  campaignId String?
  campaign   EmailCampaign? @relation("CampaignEmailLogs", fields: [campaignId], references: [id], onDelete: SetNull)

  // FIX A1-P0-002: Reverse relation for EmailEngagement FK
  engagements EmailEngagement[] @relation("EmailLogEngagements")

  @@index([sentAt])
  @@index([templateId])
  @@index([to])
  @@index([to, status])
  @@index([messageId])
  @@index([status])
  @@index([userId])
  @@index([userId, sentAt])
  @@index([campaignId])
  @@index([campaignId, status])
  @@index([tenantId])
}

// Faille #11: Persistent bounce tracking (was in-memory only, lost on restart)
model EmailBounce {
  id         String   @id @default(cuid())
  tenantId   String?
  email      String
  bounceType String   // 'hard' or 'soft'
  provider   String
  reason     String?
  messageId  String?
  count      Int      @default(1)
  lastBounce DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([email])
  @@index([email, bounceType])
  @@index([messageId])
  @@index([createdAt])
  @@index([tenantId])
}

// Faille #12: Persistent suppression list for hard-bounced/complained emails
model EmailSuppression {
  id        String   @id @default(cuid())
  tenantId  String?
  email     String   @unique
  reason    String   // 'hard_bounce', 'complaint', 'manual'
  provider  String?
  createdAt DateTime @default(now())
  expiresAt DateTime? // null = permanent suppression

  @@index([email])
  @@index([createdAt])
  @@index([tenantId])
}

model EmailTemplate {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String   @unique
  subject     String
  htmlContent String
  textContent String?
  variables   String[]
  type        String?  // transactional, marketing, notification, system
  trigger     String?  // order_confirmation, shipping_update, welcome, password_reset, etc.
  isActive    Boolean  @default(true)
  locale      String   @default("fr")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([type])
  @@index([trigger])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

model Message {
  id             String       @id @default(cuid())
  tenantId       String?
  conversationId String
  senderId       String
  type           MessageType  @default(TEXT)
  content        String
  attachmentUrl  String?
  attachmentName String?
  attachmentSize Int?
  readAt         DateTime?
  isSystem       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([conversationId])
  @@index([createdAt])
  @@index([senderId])
  @@index([tenantId])
}

model QuickReply {
  id           String                  @id @default(cuid())
  tenantId     String?
  title        String
  content      String
  category     String?
  sortOrder    Int                     @default(0)
  isActive     Boolean                 @default(true)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  translations QuickReplyTranslation[]

  @@index([category])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

model QuickReplyTranslation {
  id           String             @id @default(cuid())
  tenantId     String?
  quickReplyId String
  locale       String
  title        String?
  content      String?
  contentHash  String?
  translatedBy String?            @default("gpt-4o-mini")
  isApproved   Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  qualityLevel TranslationQuality @default(draft)
  quickReply   QuickReply         @relation(fields: [quickReplyId], references: [id], onDelete: Cascade)

  @@unique([quickReplyId, locale])
  @@index([locale])
  @@index([quickReplyId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

// =============================================
// COMMUNICATION HUB - Unified Email/Notification System
// =============================================
model InboundEmail {
  id             String                   @id @default(cuid())
  tenantId       String?
  conversationId String?
  from           String
  fromName       String?
  to             String
  subject        String
  htmlBody       String?
  textBody       String?
  messageId      String                   @unique
  inReplyTo      String?
  references     String?
  isSpam         Boolean                  @default(false)
  spamScore      Float?
  receivedAt     DateTime                 @default(now())
  conversation   EmailConversation?       @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  attachments    InboundEmailAttachment[]

  @@index([from])
  @@index([conversationId])
  @@index([messageId])
  @@index([receivedAt])
  @@index([tenantId])
}

model InboundEmailAttachment {
  id             String       @id @default(cuid())
  tenantId       String?
  inboundEmailId String
  filename       String
  mimeType       String
  size           Int
  storageUrl     String
  inboundEmail   InboundEmail @relation(fields: [inboundEmailId], references: [id], onDelete: Cascade)

  @@index([inboundEmailId])
  @@index([tenantId])
}

model EmailConversation {
  id              String                 @id @default(cuid())
  tenantId        String?
  subject         String
  customerId      String?
  assignedToId    String?
  status          String                 @default("NEW")
  priority        String                 @default("NORMAL")
  tags            String?
  slaDeadline     DateTime?
  snoozedUntil    DateTime?
  lastMessageAt   DateTime               @default(now())
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  customer        User?                  @relation("customerConversations", fields: [customerId], references: [id], onDelete: SetNull)
  assignedTo      User?                  @relation("assignedConversations", fields: [assignedToId], references: [id], onDelete: SetNull)
  inboundEmails   InboundEmail[]
  outboundReplies OutboundReply[]
  notes           ConversationNote[]
  activities      ConversationActivity[]

  @@index([customerId])
  @@index([assignedToId])
  @@index([status])
  @@index([lastMessageAt])
  @@index([snoozedUntil])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

model OutboundReply {
  id             String            @id @default(cuid())
  tenantId       String?
  conversationId String
  senderId       String
  to             String
  subject        String
  htmlBody       String
  textBody       String?
  messageId      String?
  status         String            @default("sent")
  scheduledFor   DateTime?
  sentAt         DateTime?
  createdAt      DateTime          @default(now())
  conversation   EmailConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User              @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([conversationId])
  @@index([senderId])
  @@index([messageId])
  @@index([createdAt])
  @@index([tenantId])
}

model ConversationNote {
  id             String            @id @default(cuid())
  tenantId       String?
  conversationId String
  authorId       String
  content        String
  mentions       String?
  createdAt      DateTime          @default(now())
  conversation   EmailConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author         User              @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([authorId])
  @@index([conversationId])
  @@index([createdAt])
  @@index([tenantId])
}

model ConversationActivity {
  id             String            @id @default(cuid())
  tenantId       String?
  conversationId String
  actorId        String?
  action         String
  details        String?
  createdAt      DateTime          @default(now())
  conversation   EmailConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([conversationId])
  @@index([createdAt])
  @@index([tenantId])
}

model CannedResponse {
  id         String   @id @default(cuid())
  tenantId   String?
  title      String
  content    String
  variables  String?
  category   String?
  locale     String   @default("fr")
  usageCount Int      @default(0)
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([category])
  @@index([locale])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

model EmailAutomationFlow {
  id          String               @id @default(cuid())
  tenantId    String?
  name        String
  description String?
  trigger     String
  nodes       String
  edges       String
  isActive    Boolean              @default(false)
  stats       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  executions  EmailFlowExecution[]

  @@index([trigger])
  @@index([isActive])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

model EmailCampaign {
  id           String    @id @default(cuid())
  tenantId     String?
  name         String
  subject      String
  htmlContent  String
  textContent  String?
  segmentQuery String?
  status       String    @default("DRAFT")
  scheduledAt  DateTime?
  sentAt       DateTime?
  stats        String?
  abTestConfig String?
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  // Bridge #33/#44: Emails sent by this campaign
  emailLogs    EmailLog[]          @relation("CampaignEmailLogs")

  // FIX A1-P0-002: Reverse relation for EmailEngagement FK
  engagements  EmailEngagement[]   @relation("CampaignEngagements")

  @@index([status])
  @@index([scheduledAt])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

model ConsentRecord {
  id             String    @id @default(cuid())
  tenantId       String?
  email          String
  userId         String?
  type           String
  purpose        String?   // DB-009: MARKETING, ANALYTICS, PERSONALIZATION, THIRD_PARTY
  source         String
  consentText    String
  version        String?   // DB-009: Policy version consented to
  grantedAt      DateTime  @default(now())
  expiresAt      DateTime?
  revokedAt      DateTime?
  ipAddress      String?
  userAgent      String?   // DB-009: Browser/device info at consent time
  lawfulBasis    String?   // DB-009: CONSENT, LEGITIMATE_INTEREST, CONTRACT
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  // FIX A1-P0-001: Restrict deletion to preserve GDPR consent audit trail
  user           User?     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([email])
  @@index([userId])
  @@index([type])
  @@index([email, type]) // FLAW-069: Composite for consent queries
  @@index([purpose])
  @@index([grantedAt])
  @@index([revokedAt])
  @@index([createdAt])
  @@index([tenantId])
}

// ── Email Settings & Segments ────────────────────────────────────
model EmailSettings {
  key       String   @id
  tenantId  String?
  value     String
  updatedAt DateTime @updatedAt
  @@index([updatedAt])
  @@index([tenantId])
}

model EmailAccount {
  id           String   @id @default(cuid())
  tenantId     String?
  name         String                       // Display name (e.g. "Support", "Marketing")
  email        String   @unique             // Email address (e.g. support@biocyclepeptides.com)
  displayName  String?                      // Sender display name
  replyTo      String?                      // Reply-to address (if different from email)
  provider     String   @default("resend")  // resend, sendgrid, smtp
  credentials  Json     @default("{}")      // Provider-specific credentials (encrypted JSON)
  isDefault    Boolean  @default(false)     // Default account for sending
  isActive     Boolean  @default(true)      // Account enabled/disabled
  color        String?                      // Color label for UI identification
  signature    String?  @db.Text            // HTML email signature
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isDefault])
  @@index([isActive])
  @@index([tenantId])
}

model EmailSegment {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  description String?
  query       String   // JSON: segment filter criteria
  color       String?
  contactCount Int     @default(0)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdBy])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

model EmailFlowExecution {
  id          String               @id @default(cuid())
  tenantId    String?
  flowId      String
  email       String
  currentNode String
  context     String               // JSON: execution context
  status      String               @default("WAITING") // WAITING, RUNNING, COMPLETED, FAILED, CANCELLED
  executeAt   DateTime
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  flow        EmailAutomationFlow  @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([status, executeAt])
  @@index([flowId])
  @@index([email])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

// ── CASL-Compliant Mailing List ─────────────────────────────────
model MailingListSubscriber {
  id               String                  @id @default(cuid())
  tenantId         String?
  email            String                  @unique
  name             String?
  userId           String?
  user             User?                   @relation("mailingListSubscriber", fields: [userId], references: [id], onDelete: SetNull)
  status           MailingListStatus       @default(PENDING)
  consentType      ConsentType             @default(EXPRESS)
  consentDate      DateTime                @default(now())
  consentIp        String?
  consentMethod    String? // "website_form", "checkout", "account_settings"
  confirmToken     String?                 @unique
  confirmedAt      DateTime?
  unsubscribedAt   DateTime?
  unsubscribeToken String?                 @unique
  preferences      MailingListPreference[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([email])
  @@index([status])
  @@index([confirmToken])
  @@index([unsubscribeToken])
  @@index([userId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

model MailingListPreference {
  id           String                @id @default(cuid())
  tenantId     String?
  subscriberId String
  subscriber   MailingListSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  category     String // "promotions", "promo_codes", "specials", "new_products"
  isEnabled    Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([subscriberId, category])
  @@index([subscriberId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

// DB-007: Email engagement tracking
model EmailEngagement {
  id              String         @id @default(cuid())
  tenantId        String?
  emailLogId      String?
  campaignId      String?
  recipientEmail  String
  recipientUserId String?
  subject         String?
  openedAt        DateTime?
  openCount       Int            @default(0)
  clickedAt       DateTime?
  clickCount      Int            @default(0)
  clickedLinks    Json?          // Array of {url, clickedAt}
  unsubscribedAt  DateTime?
  bouncedAt       DateTime?
  bounceType      String?        // HARD, SOFT
  complainedAt    DateTime?
  deliveredAt     DateTime?
  sentAt          DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // FIX A1-P0-002: Add @relation directives for FK fields
  emailLog        EmailLog?      @relation("EmailLogEngagements", fields: [emailLogId], references: [id], onDelete: SetNull)
  campaign        EmailCampaign? @relation("CampaignEngagements", fields: [campaignId], references: [id], onDelete: SetNull)
  recipientUser   User?          @relation("UserEmailEngagements", fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([emailLogId])
  @@index([recipientEmail])
  @@index([recipientUserId])
  @@index([campaignId])
  @@index([sentAt])
  @@index([openedAt])
  @@index([bouncedAt])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

model VoipConnection {
  id             String   @id @default(cuid())
  tenantId       String?
  provider       String   @unique // "telnyx", "voipms", "fusionpbx"
  isEnabled      Boolean  @default(false)

  // Credentials (encrypted via crypto.ts)
  apiKey         String?
  apiSecret      String?
  accountSid     String?

  // FusionPBX connection
  pbxHost        String? // "pbx.biocyclepeptides.com"
  pbxPort        Int? // 8021 (ESL)
  eslPassword    String? // encrypted

  // Sync state
  lastSyncAt     DateTime?
  syncStatus     String?
  syncError      String?

  // Audit
  configuredById String?
  configuredBy   User?    @relation("VoipConfiguredBy", fields: [configuredById], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  phoneNumbers   PhoneNumber[]
  callLogs       CallLog[]

  @@index([provider])
  @@index([configuredById])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

model PhoneNumber {
  id           String          @id @default(cuid())
  tenantId     String?
  connectionId String
  connection   VoipConnection  @relation(fields: [connectionId], references: [id], onDelete: Restrict)

  number       String          @unique // "+15145551234" E.164 format
  displayName  String? // "Support BioCycle"
  country      String // "CA", "US", "FR"
  type         PhoneNumberType @default(LOCAL)

  // Routing
  routeToIvr   String? // IVR Menu ID
  routeToQueue String? // Queue name
  routeToExt   String? // Direct extension
  forwardTo    String? // Forward to another E.164 number (alias/forwarding)

  // Multi-language & region
  language     String   @default("fr-CA") // Primary language: fr-CA, en-US, en-CA, es
  region       String?  // "Montreal", "Toronto", "Toll-Free", "US", "EU"

  isActive     Boolean         @default(true)
  monthlyCost  Decimal?        @db.Decimal(10, 2)

  // Tenant ownership
  companyId    String?
  company      Company?        @relation("CompanyPhoneNumbers", fields: [companyId], references: [id], onDelete: SetNull)

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  callLogs     CallLog[]

  @@index([connectionId])
  @@index([companyId])
  @@index([country])
  @@index([isActive])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

model SipExtension {
  id             String      @id @default(cuid())
  tenantId       String?
  userId         String
  user           User        @relation("UserExtension", fields: [userId], references: [id], onDelete: Restrict)

  extension      String      @unique // "1001", "1002"
  sipUsername    String // encrypted
  sipPassword    String // encrypted
  sipDomain      String // "pbx.biocyclepeptides.com"

  // Status
  isRegistered   Boolean     @default(false)
  lastSeenAt     DateTime?
  status         AgentStatus @default(OFFLINE)

  // FusionPBX reference
  fusionExtId    String? // UUID in FusionPBX DB
  fusionDomainId String?

  // Tenant ownership
  companyId      String?
  company        Company?    @relation("CompanySipExtensions", fields: [companyId], references: [id], onDelete: SetNull)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  callsAsAgent   CallLog[]   @relation("AgentCalls")
  voicemails     Voicemail[]

  @@index([userId])
  @@index([companyId])
  @@index([fusionExtId])
  @@index([fusionDomainId])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

model CallLog {
  id             String          @id @default(cuid())
  tenantId       String?

  // Call identification
  pbxUuid        String?         @unique // FreeSWITCH UUID
  connectionId   String?
  connection     VoipConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  // Participants
  callerNumber   String // "+15145551234"
  callerName     String? // Caller ID name
  calledNumber   String // "+15145559876"
  direction      CallDirection

  // Routing
  phoneNumberId  String?
  phoneNumber    PhoneNumber?    @relation(fields: [phoneNumberId], references: [id], onDelete: SetNull)
  agentId        String?
  agent          SipExtension?   @relation("AgentCalls", fields: [agentId], references: [id], onDelete: SetNull)
  queue          String? // Queue name if routed via queue
  ivr            String? // IVR name if passed through IVR

  // Timing
  startedAt      DateTime
  answeredAt     DateTime?
  endedAt        DateTime?
  duration       Int? // seconds (total)
  billableSec    Int? // seconds (billable)
  waitTime       Int? // seconds in queue

  // Status
  status         CallStatus      @default(RINGING)
  hangupCause    String? // FreeSWITCH hangup cause

  // CRM linking
  clientId       String?
  client         User?           @relation("ClientCalls", fields: [clientId], references: [id], onDelete: SetNull)
  companyId      String?
  company        Company?        @relation("CompanyCalls", fields: [companyId], references: [id], onDelete: SetNull)

  // Notes
  agentNotes     String?
  disposition    String? // "resolved", "callback_needed", "escalated"
  tags           String[] // ["urgent", "complaint", "billing"]

  // Metadata (JSON bag for consent tracking, custom fields, etc.)
  metadata       Json?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  recording          CallRecording?
  survey             CallSurvey?
  transcription      CallTranscription?
  dialerDisposition  DialerDisposition?
  coachingSession    CoachingSession?

  @@index([connectionId])
  @@index([phoneNumberId])
  @@index([agentId])
  @@index([clientId])
  @@index([companyId])
  @@index([callerNumber])
  @@index([calledNumber])
  @@index([direction])
  @@index([status])
  @@index([startedAt])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

model CallRecording {
  id              String   @id @default(cuid())
  tenantId        String?
  callLogId       String?  @unique
  callLog         CallLog? @relation(fields: [callLogId], references: [id], onDelete: SetNull)

  // Storage
  blobUrl         String? // Azure Blob URL
  localPath       String? // Path on PBX server (temporary)
  fileSize        Int? // bytes
  format          String   @default("wav") // "wav", "mp3", "ogg"
  durationSec     Int?

  // Video
  isVideo         Boolean  @default(false)
  videoCodec      String?
  resolution      String?

  // Processing
  isUploaded      Boolean  @default(false)
  isTranscribed   Boolean  @default(false)

  // Consent
  consentObtained Boolean  @default(false)
  consentMethod   String? // "ivr_prompt", "agent_verbal", "pre_agreed"

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transcription   CallTranscription?
  videoRoom       VideoRoom?

  @@index([isUploaded])
  @@index([isTranscribed])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

model CallTranscription {
  id             String         @id @default(cuid())
  tenantId       String?
  callLogId      String         @unique
  callLog        CallLog        @relation(fields: [callLogId], references: [id], onDelete: Restrict)
  recordingId    String?        @unique
  recording      CallRecording? @relation(fields: [recordingId], references: [id], onDelete: SetNull)

  // Content
  fullText       String // Complete transcription
  summary        String? // AI-generated summary
  actionItems    String? // AI-extracted action items (JSON array)
  sentiment      String? // "positive", "neutral", "negative"
  sentimentScore Float? // 0.0 to 1.0
  keywords       String[] // AI-extracted keywords
  language       String         @default("fr")

  // Processing
  engine         String         @default("whisper") // "whisper", "openai", "google"
  model          String? // "base.en", "medium", etc.
  confidence     Float? // Average confidence score

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([sentiment])
  @@index([language])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

model CallSurvey {
  id           String    @id @default(cuid())
  tenantId     String?
  callLogId    String    @unique
  callLog      CallLog   @relation(fields: [callLogId], references: [id], onDelete: Restrict)

  // Scores (1-5)
  overallScore Int? // "Comment evaluez-vous le service?"
  resolvedScore Int? // "Votre probleme a-t-il ete resolu?"

  // Method
  method       String    @default("dtmf") // "dtmf", "web_form"
  completedAt  DateTime?

  createdAt    DateTime  @default(now())

  @@index([overallScore])
  @@index([createdAt])
  @@index([tenantId])
}

model Voicemail {
  id            String        @id @default(cuid())
  tenantId      String?

  extensionId   String
  extension     SipExtension  @relation(fields: [extensionId], references: [id], onDelete: Restrict)

  callerNumber  String
  callerName    String?

  blobUrl       String? // Azure Blob URL
  localPath     String?
  durationSec   Int?

  transcription String? // Whisper transcription
  isRead        Boolean       @default(false)
  isArchived    Boolean       @default(false)

  // CRM linking
  clientId      String?
  client        User?         @relation("ClientVoicemails", fields: [clientId], references: [id], onDelete: SetNull)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([extensionId])
  @@index([clientId])
  @@index([isRead])
  @@index([isArchived])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

model DialerCampaign {
  id           String         @id @default(cuid())
  tenantId     String?
  companyId    String
  company      Company        @relation("CompanyCampaigns", fields: [companyId], references: [id], onDelete: Restrict)

  name         String
  description  String?
  status       CampaignStatus @default(DRAFT)

  // Dialer settings
  callerIdNumber String       // E.164 DID to use as caller ID
  maxConcurrent  Int          @default(1)  // Max simultaneous calls
  useAmd         Boolean      @default(true)  // Answering Machine Detection
  amdTimeout     Int          @default(3500)  // ms before AMD decision

  // Script
  scriptTitle    String?
  scriptBody     String?      // Rich text script for agents

  // Schedule
  startTime      String?      // "09:00" - daily start
  endTime        String?      // "17:00" - daily end
  timezone       String       @default("America/Montreal")
  activeDays     String[]     // ["mon","tue","wed","thu","fri"]

  // Stats (denormalized for performance)
  totalContacts  Int          @default(0)
  totalCalled    Int          @default(0)
  totalConnected Int          @default(0)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  dialerList     DialerListEntry[]
  dispositions   DialerDisposition[]

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([tenantId])
}

model DialerListEntry {
  id           String          @id @default(cuid())
  tenantId     String?
  campaignId   String
  campaign     DialerCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  phoneNumber  String          // E.164 number to call
  firstName    String?
  lastName     String?
  email        String?
  customFields Json?           // Flexible extra data

  // CRM bridge
  crmLeadId    String?
  crmLead      CrmLead?        @relation("DialerListLead", fields: [crmLeadId], references: [id], onDelete: SetNull)

  // State
  isCalled     Boolean         @default(false)
  callAttempts Int             @default(0)
  lastCalledAt DateTime?
  scheduledAt  DateTime?       // For callbacks

  // DNCL
  isDncl       Boolean         @default(false)
  dnclCheckedAt DateTime?

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  disposition  DialerDisposition?

  @@index([campaignId])
  @@index([isCalled])
  @@index([isDncl])
  @@index([scheduledAt])
  @@index([crmLeadId])
  @@index([createdAt])
  @@index([tenantId])
}

model DialerDisposition {
  id           String                @id @default(cuid())
  tenantId     String?
  campaignId   String
  campaign     DialerCampaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  listEntryId  String                @unique
  listEntry    DialerListEntry       @relation(fields: [listEntryId], references: [id], onDelete: Cascade)
  callLogId    String?               @unique
  callLog      CallLog?              @relation(fields: [callLogId], references: [id], onDelete: SetNull)

  type         DialerDispositionType
  notes        String?
  callbackAt   DateTime?             // When to call back

  createdAt    DateTime              @default(now())

  @@index([campaignId])
  @@index([type])
  @@index([callbackAt])
  @@index([createdAt])
  @@index([tenantId])
}

// DNCL (Do Not Call List) — Canada CRTC compliance
model DnclEntry {
  id           String   @id @default(cuid())
  tenantId     String?
  phoneNumber  String   @unique  // E.164 format
  source       String   @default("crtc") // "crtc", "internal", "customer_request"
  addedAt      DateTime @default(now())
  expiresAt    DateTime? // CRTC entries may expire
  reason       String?

  @@index([phoneNumber])
  @@index([source])
  @@index([addedAt])
  @@index([tenantId])
}

// Dialer Script Template (reusable across campaigns)
model DialerScript {
  id          String   @id @default(cuid())
  tenantId    String?
  companyId   String
  company     Company  @relation("CompanyDialerScripts", fields: [companyId], references: [id], onDelete: Restrict)
  name        String
  content     String   // Rich text / markdown script body
  category    String?  // "sales", "support", "survey"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
  @@index([isActive])
  @@index([tenantId])
}

model CallQueue {
  id           String           @id @default(cuid())
  tenantId     String?
  companyId    String
  company      Company          @relation("CompanyQueues", fields: [companyId], references: [id], onDelete: Restrict)

  name         String           // "Sales", "Support", "Formation"
  strategy     QueueStrategy    @default(RING_ALL)

  // Timing
  ringTimeout  Int              @default(30)  // seconds per agent
  maxWaitTime  Int              @default(300) // seconds in queue before overflow
  wrapUpTime   Int              @default(15)  // seconds post-call wrap up

  // Audio
  holdMusicUrl String?          // URL to hold music
  announcePosition Boolean      @default(true)
  announceInterval Int          @default(30)  // seconds between announcements

  // Overflow
  overflowAction String         @default("voicemail") // "voicemail", "ivr", "extension"
  overflowTarget String?        // Extension/IVR ID for overflow

  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  members      CallQueueMember[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([isActive])
  @@index([createdAt])
  @@index([tenantId])
}

model CallQueueMember {
  id          String       @id @default(cuid())
  tenantId    String?
  queueId     String
  queue       CallQueue    @relation(fields: [queueId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation("QueueAgent", fields: [userId], references: [id], onDelete: Restrict)

  priority    Int          @default(0)  // Lower = higher priority
  penalty     Int          @default(0)  // Weighted routing

  createdAt   DateTime     @default(now())

  @@unique([queueId, userId])
  @@index([queueId])
  @@index([userId])
  @@index([tenantId])
}

model IvrMenu {
  id           String        @id @default(cuid())
  tenantId     String?
  companyId    String
  company      Company       @relation("CompanyIvrMenus", fields: [companyId], references: [id], onDelete: Restrict)

  name         String        // "Main Menu", "After Hours"
  description  String?

  // Greeting
  greetingText String?       // TTS text for greeting
  greetingUrl  String?       // URL to audio file (overrides TTS)
  language     String        @default("fr-CA")

  // Timeout
  inputTimeout Int           @default(5)   // seconds to wait for input
  maxRetries   Int           @default(3)   // retries before timeout action
  timeoutAction String       @default("replay") // "replay", "operator", "voicemail"
  timeoutTarget String?

  // Schedule-based routing
  timezone           String  @default("America/Toronto") // IANA timezone
  businessHoursStart String? // "09:00"
  businessHoursEnd   String? // "17:00"
  afterHoursMenuId   String? // ID of after-hours IvrMenu

  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  options      IvrMenuOption[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([afterHoursMenuId])
  @@index([isActive])
  @@index([createdAt])
  @@index([tenantId])
}

model IvrMenuOption {
  id          String    @id @default(cuid())
  tenantId    String?
  menuId      String
  menu        IvrMenu   @relation(fields: [menuId], references: [id], onDelete: Cascade)

  digit       String    // "1", "2", ... "9", "0", "*", "#"
  label       String    // "Ventes", "Support", "Formation"

  // Action
  action      String    // "transfer_queue", "transfer_ext", "sub_menu", "voicemail", "external"
  target      String    // Queue name, extension, menu ID, or phone number

  // TTS announcement before action
  announcement String?  // "Transfert au departement des ventes..."

  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  @@unique([menuId, digit])
  @@index([menuId])
  @@index([tenantId])
}

model PresenceStatus {
  id          String      @id @default(cuid())
  tenantId    String?
  userId      String
  user        User        @relation("UserPresence", fields: [userId], references: [id], onDelete: Restrict)

  status      AgentStatus @default(OFFLINE)
  statusText  String?     // "En reunion", "Pause diner"

  // Connection info
  deviceType  String?     // "ios", "macos", "web"
  ipAddress   String?
  userAgent   String?

  // Timing
  onlineSince DateTime?
  lastActivity DateTime?

  updatedAt   DateTime    @updatedAt

  @@unique([userId, deviceType])
  @@index([userId])
  @@index([status])
  @@index([updatedAt])
  @@index([tenantId])
}

model CoachingSession {
  id           String                @id @default(cuid())
  tenantId     String?
  companyId    String
  company      Company               @relation("CompanyCoaching", fields: [companyId], references: [id], onDelete: Restrict)

  coachId      String
  coach        User                  @relation("CoachingCoach", fields: [coachId], references: [id], onDelete: Restrict)
  studentId    String
  student      User                  @relation("CoachingStudent", fields: [studentId], references: [id], onDelete: Restrict)
  supervisorId String?
  supervisor   User?                 @relation("CoachingSupervisor", fields: [supervisorId], references: [id], onDelete: SetNull)

  // Call reference (one-to-one with CallLog)
  callLogId    String?               @unique
  callLog      CallLog?              @relation(fields: [callLogId], references: [id], onDelete: SetNull)

  // Session info
  status       CoachingSessionStatus @default(SCHEDULED)
  scheduledAt  DateTime
  startedAt    DateTime?
  endedAt      DateTime?
  durationMin  Int?

  // Evaluation
  topic        String?               // "Techniques de vente", "Reclamations"
  objectives   String?               // What should be practiced
  feedback     String?               // Coach's written feedback

  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  scores       CoachingScore[]

  @@index([companyId])
  @@index([coachId])
  @@index([studentId])
  @@index([supervisorId])
  @@index([status])
  @@index([scheduledAt])
  @@index([createdAt])
  @@index([tenantId])
}

model CoachingScore {
  id          String          @id @default(cuid())
  tenantId    String?
  sessionId   String
  session     CoachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  criterion   String          // "Accueil client", "Ecoute active", "Argumentation"
  score       Int             // 1-10
  weight      Float           @default(1.0) // Weight for weighted average
  comment     String?         // Coach comment on this criterion
  isAutoScored Boolean        @default(false) // AI vs manual scoring

  createdAt   DateTime        @default(now())

  @@unique([sessionId, criterion])
  @@index([sessionId])
  @@index([criterion])
  @@index([tenantId])
}

// H6: SMS Log — tracks all SMS sent through the system
model SmsLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  to        String
  body      String
  status    String   @default("sent") // sent, delivered, failed, queued
  provider  String   @default("twilio")
  messageId String?  // Provider message ID for tracking
  errorMsg  String?
  sentAt    DateTime @default(now())
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([to])
  @@index([status])
  @@index([messageId])
  @@index([sentAt])
  @@index([tenantId])
}

// --- J7: SMS Marketing ---
model SmsCampaign {
  id               String              @id @default(cuid())
  tenantId         String?
  name             String
  status           SmsCampaignStatus   @default(DRAFT)
  templateId       String?
  template         SmsTemplate?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  message          String?
  segmentCriteria  Json?
  scheduledAt      DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  totalRecipients  Int                 @default(0)
  sent             Int                 @default(0)
  delivered        Int                 @default(0)
  failed           Int                 @default(0)
  optedOut         Int                 @default(0)
  createdById      String
  createdBy        User                @relation("SmsCampaignCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  messages SmsCampaignMessage[]

  @@index([status])
  @@index([createdById])
  @@index([templateId])
  @@index([scheduledAt])
  @@index([createdAt])
  @@index([tenantId])
}

model SmsCampaignMessage {
  id          String                    @id @default(cuid())
  tenantId    String?
  campaignId  String
  campaign    SmsCampaign               @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  recipientId String?
  recipient   User?                     @relation("SmsCampaignRecipient", fields: [recipientId], references: [id], onDelete: SetNull)
  phone       String
  status      SmsCampaignMessageStatus  @default(PENDING)
  sentAt      DateTime?
  deliveredAt DateTime?
  errorMessage String?
  createdAt   DateTime                  @default(now())

  @@index([campaignId])
  @@index([recipientId])
  @@index([status])
  @@index([tenantId])
}

model SmsOptOut {
  id        String   @id @default(cuid())
  tenantId  String?
  phone     String   @unique
  reason    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([tenantId])
}

model SmsTemplate {
  id        String        @id @default(cuid())
  tenantId  String?
  name      String
  body      String
  variables String[]      @default([])
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  campaigns SmsCampaign[]

  @@index([isActive])
  @@index([tenantId])
}

// =============================================================
// Aurelia AI Chat (Real Aurelia via Mac Studio bridge)
// =============================================================

model AureliaChat {
  id               String   @id @default(cuid())
  tenantId         String?
  conversationId   String
  userId           String
  content          String   @db.Text
  role             String   // USER, AURELIA, SYSTEM
  status           String   @default("PENDING") // PENDING, PROCESSING, ANSWERED, FAILED
  contextUsed      Json?    // Vector results + knowledge used
  processingTimeMs Int?
  voiceUrl         String?  // Pre-generated TTS audio URL (cache)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation("aureliaChats", fields: [userId], references: [id])

  @@index([conversationId, createdAt])
  @@index([status])
  @@index([userId, createdAt])
  @@index([tenantId])
}
