// FormatType enum removed — optionType is now a String field
// Managed dynamically via FormatTypeOption table in admin UI

model FormatTypeOption {
  id        String   @id @default(cuid())
  tenantId  String?
  value     String   @unique   // e.g. "VIAL_2ML", "CAPSULE_60"
  label     String              // Display label in French
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@index([tenantId])
}

