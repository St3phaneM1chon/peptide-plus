// ---------------------------------------------------------------------------
// Social Post (Social Scheduler)
// ---------------------------------------------------------------------------
model SocialPost {
  id          String    @id @default(cuid())
  tenantId    String?
  platform    String    // "instagram", "facebook", "twitter", "tiktok", "linkedin"
  content     String    @db.Text
  imageUrl    String?
  scheduledAt DateTime
  publishedAt DateTime?
  status      String    @default("draft") // draft, scheduled, publishing, published, failed
  error       String?
  externalId  String? // ID of the post on the platform
  externalUrl String? // URL of the published post
  createdById String?
  createdBy    User?     @relation("SocialPosts", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  translations SocialPostTranslation[]

  @@index([status, scheduledAt])
  @@index([platform])
  @@index([createdById])
  @@index([externalId])
  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Social Post Translation (i18n)
// ---------------------------------------------------------------------------
model SocialPostTranslation {
  id           String   @id @default(cuid())
  tenantId     String?
  socialPostId String
  locale       String   @db.VarChar(10)
  content      String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  socialPost   SocialPost @relation(fields: [socialPostId], references: [id], onDelete: Cascade)

  @@unique([socialPostId, locale])
  @@index([socialPostId])
  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Ad Campaign Snapshot (Ads Dashboard)
// ---------------------------------------------------------------------------
model AdCampaignSnapshot {
  id           String   @id @default(cuid())
  tenantId     String?
  platform     String // "youtube", "google-ads", "tiktok", "x", "linkedin", "meta"
  campaignId   String?
  campaignName String?
  date         DateTime @db.Date
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  spend        Decimal  @default(0) @db.Decimal(12, 2)
  conversions  Int      @default(0)
  currency     String   @default("CAD")
  rawData      Json? // Raw data from the platform
  createdAt    DateTime @default(now())

  @@unique([platform, campaignId, date])
  @@index([platform, date])
  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// SEO Audit Result (automated SEO auditing per page)
// ---------------------------------------------------------------------------
model SeoAuditResult {
  id        String   @id @default(cuid())
  tenantId  String?
  pageUrl   String
  score     Int      // 0-100
  issues    Json     @default("[]") // [{type, severity, message, suggestion}]
  metadata  Json     @default("{}") // title, description, og, keywords found
  lastAudit DateTime @default(now())

  @@unique([tenantId, pageUrl])
  @@index([tenantId, score])
}

// ---------------------------------------------------------------------------
// A/B Test (split testing for pages)
// ---------------------------------------------------------------------------
model AbTest {
  id        String    @id @default(cuid())
  tenantId  String?
  name      String
  pageUrl   String
  status    String    @default("draft") // draft, running, paused, completed
  variants  Json      // [{id, name, content, trafficPercent}]
  metrics   Json      @default("{}") // {impressions, conversions, conversionRate per variant}
  startDate DateTime?
  endDate   DateTime?
  winnerId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  impressions AbTestImpression[]

  @@index([tenantId, status])
}

// ---------------------------------------------------------------------------
// A/B Test Impression (visitor tracking for A/B tests)
// ---------------------------------------------------------------------------
model AbTestImpression {
  id        String   @id @default(cuid())
  tenantId  String?
  testId    String
  variantId String
  visitorId String
  converted Boolean  @default(false)
  createdAt DateTime @default(now())

  test AbTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId, variantId])
  @@index([tenantId, createdAt])
}

// ---------------------------------------------------------------------------
// Shoppable Link (Social Commerce — trackable product links for social media)
// ---------------------------------------------------------------------------
model ShoppableLink {
  id          String    @id @default(cuid())
  tenantId    String?
  shortCode   String    @unique
  fullUrl     String
  productId   String
  productName String
  platform    String    // instagram, facebook, tiktok, twitter, linkedin, pinterest, whatsapp, email, sms, other
  utmSource   String
  utmMedium   String
  utmCampaign String
  utmContent  String?
  clicks      Int       @default(0)
  conversions Int       @default(0)
  revenue     Decimal   @default(0) @db.Decimal(12, 2)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  product     Product   @relation("ProductShoppableLinks", fields: [productId], references: [id], onDelete: Cascade)
  clickEvents ShoppableLinkClick[]

  @@index([tenantId])
  @@index([shortCode])
  @@index([productId])
  @@index([platform])
  @@index([utmCampaign])
}

// ---------------------------------------------------------------------------
// Shoppable Link Click (individual click tracking)
// ---------------------------------------------------------------------------
model ShoppableLinkClick {
  id               String   @id @default(cuid())
  tenantId         String?
  shoppableLinkId  String
  referrer         String?
  userAgent        String?
  ipHash           String?  // SHA-256 truncated hash (privacy-safe)
  createdAt        DateTime @default(now())

  shoppableLink    ShoppableLink @relation(fields: [shoppableLinkId], references: [id], onDelete: Cascade)

  @@index([shoppableLinkId])
  @@index([tenantId, createdAt])
}
