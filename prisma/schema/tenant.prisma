// =============================================================================
// MULTI-TENANT — Koraline SaaS Platform
// =============================================================================
// Chaque client Koraline est un "tenant" isolé.
// tenant_id est injecté automatiquement par le middleware Prisma dans db.ts
// RLS PostgreSQL sert de filet de sécurité supplémentaire.

model Tenant {
  id              String    @id @default(cuid())
  slug            String    @unique                  // ex: "biocycle", "attitudes"
  name            String                             // ex: "BioCycle Peptides"
  domainCustom             String?   @unique           // ex: "biocyclepeptides.com"
  domainKoraline           String?   @unique           // ex: "biocycle.koraline.app"
  domainVerified           Boolean   @default(false)   // DNS TXT ownership verified
  domainVerificationToken  String?                     // TXT record value for _attitudes-verify.{domain}
  plan            String    @default("pro")          // essential, pro, enterprise
  status          TenantStatus @default(ACTIVE)

  // Branding
  logoUrl         String?
  primaryColor    String    @default("#0066CC")
  secondaryColor  String    @default("#003366")
  font            String    @default("Inter")

  // Configuration
  modulesEnabled  Json      @default("[]")           // ["commerce","crm","marketplace_pro"]
  featuresFlags   Json      @default("{}")            // {"live_shopping":false,"ai_repricing":true}
  locale          String    @default("fr")
  timezone        String    @default("America/Toronto")
  currency        String    @default("CAD")

  // Taxes — activables/désactivables par tenant (D72)
  // Beaucoup de PPE/PME ne perçoivent pas les taxes au départ
  taxEnabled          Boolean   @default(false)           // Master toggle : percevoir les taxes ou non
  taxGstNumber        String?                             // Numéro TPS fédéral (ex: 123456789RT0001)
  taxQstNumber        String?                             // Numéro TVQ Québec (ex: 1234567890TQ0001)
  taxHstNumber        String?                             // Numéro TVH (provinces harmonisées)
  taxPstNumber        String?                             // Numéro PST (BC, SK, MB)
  taxProvince         String    @default("QC")            // Province du tenant (pour déterminer les taxes applicables)
  taxConfig           Json      @default("{}")            // Config avancée : {"gst":true,"qst":true,"pst":false,"rates_override":{}}

  // Stripe
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique

  // Contacts par département
  contactFinanceName    String?
  contactFinanceEmail   String?
  contactFinancePhone   String?
  contactSupportName    String?
  contactSupportEmail   String?
  contactSupportPhone   String?
  contactTechName       String?
  contactTechEmail      String?
  contactTechPhone      String?
  contactMarketingName  String?
  contactMarketingEmail String?
  contactMarketingPhone String?

  // Info supplémentaire
  legalName             String?
  shortDescription      String?
  longDescription       String?
  industry              String?
  notes                 String?

  // Adresse
  address               String?
  city                  String?
  province              String?
  postalCode            String?
  country               String?   @default("CA")

  // Metadata
  ownerUserId     String?
  maxEmployees    Int       @default(3)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  suspendedAt     DateTime?
  suspendedReason String?

  // Relations
  events          TenantEvent[]
  notifications   TenantNotification[]

  @@index([status])
  @@index([plan])
  @@index([createdAt])
}

model TenantEvent {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      String
  actor     String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}

model TenantNotification {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  createdBy String?
  createdAt DateTime @default(now())

  @@index([tenantId, read])
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  PENDING
  CANCELLED
}
