  course    Course        @relation(fields: [courseId], references: [id], onDelete: Restrict)
  sortOrder Int           @default(0)

  @@unique([bundleId, courseId])
  @@index([bundleId, sortOrder])
  @@index([courseId])
}

// =============================================================================
// COMPTES CORPORATIFS (PARRAINAGE)
// =============================================================================

enum CorporateBillingMethod {
  STRIPE
  INVOICE
  PURCHASE_ORDER
  PREPAID
}

model CorporateAccount {
  id                String   @id @default(cuid())
  tenantId          String
  companyName       String                          // "Chubb Insurance", "Industrielle Alliance"
  companyId         String?                         // Lien optionnel vers Company (ecommerce)
  company           Company? @relation("CompanyCorporateAccounts", fields: [companyId], references: [id], onDelete: SetNull)
  slug              String
  contactEmail      String
  contactName       String?
  contactPhone      String?

  // Facturation
  billingMethod     CorporateBillingMethod @default(INVOICE)
  stripeCustomerId  String?
  paymentTermsDays  Int      @default(30)           // Net 30, Net 60, etc.
  creditLimit       Decimal? @db.Decimal(10, 2)

  // Budget formation
  budgetAmount      Decimal? @db.Decimal(10, 2)     // Budget annuel formation
  budgetUsed        Decimal  @default(0) @db.Decimal(10, 2)
  budgetPeriodStart DateTime?
  budgetPeriodEnd   DateTime?

  // Rabais
  discountPercent   Decimal  @default(0) @db.Decimal(5, 2) // Rabais global (ex: 15%)

  isActive          Boolean  @default(true)

  // Relations
  employees         CorporateEmployee[]
  enrollments       Enrollment[]
  bundleOrders      CourseBundleOrder[]
  courseOrders       CourseOrder[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, isActive])
  @@index([companyId])
}

model CorporateEmployee {
  id                 String           @id @default(cuid())
  tenantId           String
  corporateAccountId String
  corporateAccount   CorporateAccount @relation(fields: [corporateAccountId], references: [id], onDelete: Cascade)
  userId             String
  employeeId         String?          // ID interne de la compagnie
  department         String?
  role               String           @default("EMPLOYEE") // ADMIN, MANAGER, EMPLOYEE
  isActive           Boolean          @default(true)

  addedAt            DateTime         @default(now())
  addedBy            String?

  @@unique([corporateAccountId, userId])
  @@index([tenantId, userId])
  @@index([corporateAccountId, isActive])
}

// =============================================================================
// COMMANDES FORFAITS
// =============================================================================

enum CoursePaymentType {
  INDIVIDUAL
  CORPORATE
  FREE
}

model CourseBundleOrder {
  id                    String            @id @default(cuid())
  tenantId              String
  userId                String
  bundleId              String
  bundle                CourseBundle      @relation(fields: [bundleId], references: [id], onDelete: Restrict)

  // Prix
  amount                Decimal           @db.Decimal(10, 2)
  currency              String            @default("CAD")
  taxAmount             Decimal           @default(0) @db.Decimal(10, 2)
  totalAmount           Decimal           @db.Decimal(10, 2)
  discountAmount        Decimal           @default(0) @db.Decimal(10, 2)

  // Paiement
  paymentType           CoursePaymentType @default(INDIVIDUAL)
  stripePaymentIntentId String?           @unique
  paidAt                DateTime?

  // Parrainage corporatif
  corporateAccountId    String?
  corporateAccount      CorporateAccount? @relation(fields: [corporateAccountId], references: [id], onDelete: SetNull)
  purchaseOrderNumber   String?
  invoiceNumber         String?

  status                String            @default("pending") // pending, paid, refunded, cancelled

  // Enrollments crees
  enrollmentIds         String[]          @default([])

  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([tenantId, userId])
  @@index([tenantId, status])
  @@index([corporateAccountId])
  @@index([stripePaymentIntentId])
}

// =============================================================================
// SOCIAL LEARNING — Forums, Q&A, Annonces
// =============================================================================

model CourseDiscussion {
  id        String   @id @default(cuid())
  tenantId  String
  courseId   String
  userId    String                          // Author
  title     String
  content   String
  isPinned  Boolean  @default(false)
  isLocked  Boolean  @default(false)        // No more replies allowed
  replyCount Int     @default(0)

  replies   CourseDiscussionReply[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, courseId, createdAt])
  @@index([tenantId, courseId, isPinned])
}

model CourseDiscussionReply {
  id           String   @id @default(cuid())
  tenantId     String
  discussionId String
  discussion   CourseDiscussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  userId       String                       // Author
  content      String
  isInstructor Boolean  @default(false)     // Marked as instructor response
  upvotes      Int      @default(0)
  parentReplyId String?                     // Nested replies

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([discussionId, createdAt])
}

model LessonQA {
