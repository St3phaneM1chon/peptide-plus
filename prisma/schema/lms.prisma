  platform    String   @default("zoom")     // zoom, teams, meet, other
  meetingUrl  String?                       // Join URL
  meetingId   String?                       // Platform meeting ID
  passcode    String?                       // Meeting passcode
  recordingUrl String?                      // Post-session recording

