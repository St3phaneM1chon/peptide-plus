  tenantId  String
  lessonId  String
  userId    String                          // Who asked
  question  String
  isResolved Boolean @default(false)

  answers   LessonQAAnswer[]
  upvotes   Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, lessonId, createdAt])
  @@index([tenantId, lessonId, isResolved])
}

model LessonQAAnswer {
  id         String   @id @default(cuid())
  tenantId   String
  qaId       String
  qa         LessonQA @relation(fields: [qaId], references: [id], onDelete: Cascade)
  userId     String
  content    String
  isAccepted Boolean  @default(false)       // Marked as best answer
  isInstructor Boolean @default(false)
  upvotes    Int      @default(0)

  createdAt  DateTime @default(now())

  @@index([qaId, createdAt])
}

model CourseAnnouncement {
  id        String   @id @default(cuid())
  tenantId  String
  courseId   String
  userId    String                          // Admin/instructor who posted
  title     String
  content   String
  isPinned  Boolean  @default(false)
  isEmail   Boolean  @default(false)        // Also sent via email

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, courseId, createdAt])
}

// =============================================================================
// IN-APP NOTIFICATIONS
// =============================================================================

model LmsNotification {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String                          // Recipient
  type      String                          // enrollment, completion, badge, announcement, deadline, qa_answer
