  tenantId  String
  userId    String
  amount    Int                             // XP gained (positive) or spent (negative)
  reason    String                          // lesson_complete, quiz_pass, course_complete, streak_bonus, challenge, daily_login
  sourceId  String?                         // ID of the triggering entity
  balance   Int                             // Running balance after this transaction

