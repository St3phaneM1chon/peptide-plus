// ============================================================
// CHANTIER H: CRM Models
// ============================================================
// H5: Customer Notes — internal notes on customer profiles
model CustomerNote {
  id        String   @id @default(cuid())
  userId    String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // FIX A1-P0-006: Preserve CRM notes when user is deleted
  user      User     @relation("customerNotes", fields: [userId], references: [id], onDelete: Restrict)
  author    User     @relation("authoredNotes", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([authorId])
}

// Workflow/Approval system (Phase 3-7)
model WorkflowRule {
  id           String   @id @default(cuid())
  name         String
  description  String?
  entityType   String   // JOURNAL_ENTRY, EXPENSE, PURCHASE_ORDER, etc.
  triggerEvent String   // CREATE, UPDATE, STATUS_CHANGE, AMOUNT_THRESHOLD
  conditions   Json     // WorkflowCondition[]
  actions      Json     // WorkflowAction[]
  priority     Int      @default(0)
  isActive     Boolean  @default(true)
  createdBy    String?
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  approvalRequests ApprovalRequest[]

  @@index([entityType, isActive])
}

model ApprovalRequest {
  id              String        @id @default(cuid())
  workflowRuleId  String?
  workflowRule    WorkflowRule? @relation(fields: [workflowRuleId], references: [id])
  entityType      String
  entityId        String
  entitySummary   String?
  amount          Decimal?
  status          String        @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED, EXPIRED
  requestedBy     String?
  requestedAt     DateTime      @default(now())
  assignedRole    String?
  assignedTo      String?
  expiresAt       DateTime?
  respondedBy     String?
  respondedAt     DateTime?
  responseNote    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([entityType, entityId])
  @@index([status, assignedRole])
  @@index([status, assignedTo])
  @@index([workflowRuleId])
}

// --- J1: CRM Lead ---
model CrmLead {
  id              String          @id @default(cuid())
  companyName     String?
  contactName     String
  email           String?
  phone           String?
  source          LeadSource      @default(MANUAL)
  status          LeadStatus      @default(NEW)
  score           Int             @default(0) // 0-100
  temperature     LeadTemperature @default(COLD)
  assignedToId    String?
  assignedTo      User?           @relation("CrmLeadAssignee", fields: [assignedToId], references: [id])
  convertedDealId String?         @unique
  convertedDeal   CrmDeal?        @relation("ConvertedFromLead", fields: [convertedDealId], references: [id])
  tags            String[]        @default([])
  customFields    Json?
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  dncStatus       DncStatus       @default(CALLABLE)
  timezone        String?
  preferredLang   String?
  // 3B.2: BANT/MEDDIC qualification
  qualificationFramework String?  // 'BANT' | 'MEDDIC' | 'CUSTOM'
  qualificationData      Json?    // { budget, authority, need, timeline } or MEDDIC fields
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  deals               CrmDeal[]            @relation("LeadDeals")
  tasks               CrmTask[]            @relation("CrmTaskLead")
  activities          CrmActivity[]        @relation("CrmActivityLead")
  inboxConversations  InboxConversation[]  @relation("InboxConversationLead")
  sourceProspect      Prospect?            @relation("ProspectToLead")
  dialerEntries       DialerListEntry[]    @relation("DialerListLead")

  // FIX A1-P0-002: Reverse relation for CrmConsentRecord FK
  consentRecords      CrmConsentRecord[]   @relation("CrmLeadConsentRecords")

  @@index([status, assignedToId])
  @@index([assignedToId, status]) // A7-P2: Reverse composite for queries filtering by assignedToId first
  @@index([score(sort: Desc)])
  @@index([nextFollowUpAt])
  @@index([source])
  @@index([temperature])
  @@index([dncStatus])
  @@index([createdAt])
  @@index([updatedAt])
}

// --- J2: CRM Pipeline + Stages ---
model CrmPipeline {
  id        String             @id @default(cuid())
  name      String
  isDefault Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  stages CrmPipelineStage[]
  deals  CrmDeal[]

  @@index([isDefault])
}

model CrmPipelineStage {
  id          String      @id @default(cuid())
  pipelineId  String
  pipeline    CrmPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  name        String
  position    Int
  probability Float       @default(0) // 0.0 - 1.0
  color       String?
  isWon       Boolean     @default(false)
  isLost      Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  deals          CrmDeal[]              @relation("DealStage")
  historyFrom    CrmDealStageHistory[]  @relation("StageHistoryFrom")
  historyTo      CrmDealStageHistory[]  @relation("StageHistoryTo")

  @@unique([pipelineId, position])
  @@index([pipelineId])
}

// --- J3: CRM Deal ---
model CrmDeal {
  id                String           @id @default(cuid())
  title             String
  value             Decimal          @default(0)
  currency          String           @default("CAD")
  stageId           String
  stage             CrmPipelineStage @relation("DealStage", fields: [stageId], references: [id])
  pipelineId        String
  pipeline          CrmPipeline      @relation(fields: [pipelineId], references: [id])
  leadId            String?
  lead              CrmLead?         @relation("LeadDeals", fields: [leadId], references: [id])
  contactId         String?
  contact           User?            @relation("CrmDealContact", fields: [contactId], references: [id])
  assignedToId      String
  assignedTo        User             @relation("CrmDealAssignee", fields: [assignedToId], references: [id])
  expectedCloseDate DateTime?
  actualCloseDate   DateTime?
  lostReason        String?
  wonReason         String?
  tags              String[]         @default([])
  customFields      Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // 3B.6: Recurring Revenue
  isRecurring       Boolean                @default(false)
  recurringInterval String?                // 'monthly' | 'quarterly' | 'yearly'
  mrrValue          Decimal?               @db.Decimal(12, 2)

  convertedFromLead CrmLead?               @relation("ConvertedFromLead")
  stageHistory      CrmDealStageHistory[]
  activities        CrmActivity[]          @relation("CrmActivityDeal")
  tasks             CrmTask[]              @relation("CrmTaskDeal")
  products          CrmDealProduct[]
  quotes            CrmQuote[]
  // Bridge: orders generated from this deal
  orders            Order[]                @relation("DealOrders")

  // FIX A1-P0-002: Reverse relations for newly added FKs
  dealTeamMembers   CrmDealTeam[]          @relation("CrmDealTeamMembers")
  contracts         CrmContract[]          @relation("CrmDealContracts")

  @@index([stageId, assignedToId])
  @@index([assignedToId]) // A7-P2: Standalone index for deals filtered by assignedToId alone
  @@index([pipelineId])
  @@index([expectedCloseDate])
  @@index([leadId])
  @@index([contactId])
  @@index([createdAt])
  @@index([updatedAt])
}

// --- J3b: Deal Products ---
model CrmDealProduct {
  id        String   @id @default(cuid())
  dealId    String
  deal      CrmDeal  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(10, 2)
  discount  Decimal  @default(0) @db.Decimal(5, 2) // percentage
  total     Decimal  @db.Decimal(10, 2)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dealId, productId])
  @@index([dealId])
  @@index([productId])
}

// --- J4: Deal Stage History ---
model CrmDealStageHistory {
  id          String           @id @default(cuid())
  dealId      String
  deal        CrmDeal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  fromStageId String?
  fromStage   CrmPipelineStage? @relation("StageHistoryFrom", fields: [fromStageId], references: [id])
  toStageId   String
  toStage     CrmPipelineStage @relation("StageHistoryTo", fields: [toStageId], references: [id])
  changedById String
  changedBy   User             @relation("CrmDealStageChanger", fields: [changedById], references: [id])
  duration    Int              @default(0) // seconds in previous stage
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([dealId])
  @@index([createdAt])
  @@index([fromStageId])
  @@index([toStageId])
  @@index([changedById])
}

// --- J5: CRM Task + Activity ---
model CrmTask {
  id           String          @id @default(cuid())
  title        String
  description  String?
  type         CrmTaskType     @default(OTHER)
  priority     CrmTaskPriority @default(MEDIUM)
  status       CrmTaskStatus   @default(PENDING)
  dueAt        DateTime?
  completedAt  DateTime?
  assignedToId String
  assignedTo   User            @relation("CrmTaskAssignee", fields: [assignedToId], references: [id])
  dealId       String?
  deal         CrmDeal?        @relation("CrmTaskDeal", fields: [dealId], references: [id])
  leadId       String?
  lead         CrmLead?        @relation("CrmTaskLead", fields: [leadId], references: [id])
  contactId    String?
  contact      User?           @relation("CrmTaskContact", fields: [contactId], references: [id])
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([assignedToId, status])
  @@index([dueAt])
  @@index([dealId])
  @@index([leadId])
  @@index([contactId])
  @@index([createdAt])
}

model CrmActivity {
  id            String          @id @default(cuid())
  type          CrmActivityType
  title         String
  description   String?
  metadata      Json?
  dealId        String?
  deal          CrmDeal?        @relation("CrmActivityDeal", fields: [dealId], references: [id])
  leadId        String?
  lead          CrmLead?        @relation("CrmActivityLead", fields: [leadId], references: [id])
  contactId     String?
  contact       User?           @relation("CrmActivityContact", fields: [contactId], references: [id])
  performedById String?
  performedBy   User?           @relation("CrmActivityPerformer", fields: [performedById], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([dealId])
  @@index([leadId])
  @@index([contactId])
  @@index([performedById])
  @@index([type])
  @@index([createdAt])
}

// --- J6: Unified Inbox ---
model InboxConversation {
  id            String       @id @default(cuid())
  channel       InboxChannel
  status        InboxStatus  @default(OPEN)
  subject       String?
  contactId     String?
  contact       User?        @relation("InboxContact", fields: [contactId], references: [id])
  leadId        String?
  lead          CrmLead?     @relation("InboxConversationLead", fields: [leadId], references: [id])
  assignedToId  String?
  assignedTo    User?        @relation("InboxAssignee", fields: [assignedToId], references: [id])
  slaDeadline   DateTime?
  lastMessageAt DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  messages InboxMessage[]

  @@index([channel, status])
  @@index([assignedToId])
  @@index([contactId])
  @@index([leadId])
  @@index([lastMessageAt])
  @@index([createdAt])
}

model InboxMessage {
  id              String            @id @default(cuid())
  conversationId  String
  conversation    InboxConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction       MessageDirection
  content         String
  senderName      String?
  senderEmail     String?
  senderPhone     String?
  metadata        Json?  // callLogId, emailId, etc.
  readAt          DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([conversationId])
  @@index([createdAt])
}

model SlaPolicy {
  id                   String   @id @default(cuid())
  name                 String
  firstResponseMinutes Int
  resolutionMinutes    Int
  priority             SlaPriority @default(MEDIUM)
  isActive             Boolean  @default(true)
  channels             String[] @default([])
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([isActive])
  @@index([priority])
}

// --- J8: Agent Daily Stats ---
model AgentDailyStats {
  id            String   @id @default(cuid())
  agentId       String
  agent         User     @relation("AgentDailyStatsAgent", fields: [agentId], references: [id])
  date          DateTime @db.Date
  callsMade     Int      @default(0)
  callsReceived Int      @default(0)
  callsAnswered Int      @default(0)
  totalTalkTime Int      @default(0) // seconds
  totalWrapTime Int      @default(0) // seconds
  avgHandleTime Float    @default(0)
  avgTalkTime   Float    @default(0)
  conversions   Int      @default(0)
  revenue       Decimal  @default(0)
  loginTime     DateTime?
  logoutTime    DateTime?
  breakTime     Int      @default(0) // seconds
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([agentId, date])
  @@index([agentId])
  @@index([date])
}

// --- K1: CRM Workflow ---
model CrmWorkflow {
  id          String              @id @default(cuid())
  name        String
  description String?
  status      WorkflowStatus      @default(DRAFT)
  triggerType WorkflowTriggerType
  triggerConfig Json?             // e.g. { stageId: "...", threshold: 70 }
  createdById String
  createdBy   User                @relation("CrmWorkflowCreator", fields: [createdById], references: [id])
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  steps       CrmWorkflowStep[]
  executions  CrmWorkflowExecution[]

  // FIX A1-P0-002: Reverse relation for CrmWorkflowVersion FK
  versions    CrmWorkflowVersion[] @relation("CrmWorkflowVersions")

  @@index([status])
  @@index([triggerType])
  @@index([createdById])
}

model CrmWorkflowStep {
  id          String            @id @default(cuid())
  workflowId  String
  workflow    CrmWorkflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  position    Int
  actionType  WorkflowActionType
  config      Json              // action-specific config
  delayMinutes Int              @default(0)
  conditionJson Json?           // optional condition to execute this step
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([workflowId, position])
  @@index([workflowId])
}

model CrmWorkflowExecution {
  id          String                    @id @default(cuid())
  workflowId  String
  workflow    CrmWorkflow               @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  entityType  String                    // 'lead' | 'deal'
  entityId    String
  status      WorkflowExecutionStatus   @default(RUNNING)
  currentStep Int                       @default(0)
  startedAt   DateTime                  @default(now())
  completedAt DateTime?
  error       String?
  log         Json?                     // step-by-step execution log

  @@index([workflowId])
  @@index([status])
  @@index([entityType, entityId])
}

// --- K2: CRM Campaign ---
model CrmCampaign {
  id              String              @id @default(cuid())
  name            String
  type            CrmCampaignType
  status          CrmCampaignStatus   @default(DRAFT)
  description     String?
  targetCriteria  Json?           // filter criteria for leads
  startAt         DateTime?
  endAt           DateTime?
  createdById     String
  createdBy       User            @relation("CrmCampaignCreator", fields: [createdById], references: [id])
  // Stats
  totalLeads      Int             @default(0)
  contacted       Int             @default(0)
  connected       Int             @default(0)
  converted       Int             @default(0)
  revenue         Decimal         @default(0)
  // Settings
  callerIdNumber  String?
  maxAttemptsPerLead Int          @default(3)
  retryIntervalHours Int          @default(24)
  callScriptId    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  activities      CrmCampaignActivity[]

  @@index([status])
  @@index([type])
  @@index([createdById])
  @@index([callScriptId])
}

model CrmCampaignActivity {
  id          String      @id @default(cuid())
  campaignId  String
  campaign    CrmCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadId      String
  attempt     Int         @default(1)
  channel     String      // 'call' | 'email' | 'sms'
  status      String      // 'pending' | 'completed' | 'failed' | 'skipped'
  disposition String?
  notes       String?
  callLogId   String?
  duration    Int?        // seconds
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([campaignId])
  @@index([leadId])
  @@index([status])
  @@index([callLogId])
}

// --- K3: Consent & Compliance ---
model CrmConsentRecord {
  id          String            @id @default(cuid())
  phone       String?
  email       String?
  channel     CrmConsentChannel @default(ALL)
  type        String            // 'express' | 'implied' | 'opt_in' | 'opt_out'
  source      String            // 'web_form' | 'verbal' | 'written' | 'import'
  grantedAt   DateTime          @default(now())
  revokedAt   DateTime?
  expiresAt   DateTime?
  notes       String?
  leadId      String?
  userId      String?           // if tied to a User
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // FIX A1-P0-002: Add @relation directives for FK fields
  lead        CrmLead?          @relation("CrmLeadConsentRecords", fields: [leadId], references: [id], onDelete: SetNull)
  user        User?             @relation("UserCrmConsentRecords", fields: [userId], references: [id], onDelete: SetNull)

  @@index([phone])
  @@index([email])
  @@index([channel])
  @@index([leadId])
  @@index([userId])
}

model CallingRule {
  id                String   @id @default(cuid())
  name              String
  timezone          String   // e.g. "America/Toronto"
  startHour         Int      @default(9)   // 9 AM
  endHour           Int      @default(21)  // 9 PM (CRTC: 9h-21h30)
  endMinute         Int      @default(30)
  weekendAllowed    Boolean  @default(false)
  holidayAllowed    Boolean  @default(false)
  maxAttemptsPerDay Int      @default(3)
  maxAttemptsTotal  Int      @default(10)
  retryIntervalMin  Int      @default(60)  // minutes between attempts
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([isActive])
}

// --- K4: CRM Quota ---
model CrmQuota {
  id        String   @id @default(cuid())
  agentId   String
  agent     User     @relation("CrmQuotaAgent", fields: [agentId], references: [id])
  period    String   // 'daily' | 'weekly' | 'monthly' | 'quarterly'
  periodStart DateTime
  periodEnd   DateTime
  targetType  String   // 'calls' | 'revenue' | 'deals' | 'conversions'
  target      Decimal
  actual      Decimal  @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agentId])
  @@index([period, periodStart])
}

// --- K5: Scheduled Report ---
model CrmScheduledReport {
  id          String   @id @default(cuid())
  name        String
  reportType  String   // 'pipeline' | 'campaign' | 'agent' | 'calls' | 'custom'
  config      Json     // filters, groupings, metrics
  schedule    String   // 'daily' | 'weekly' | 'monthly'
  recipients  String[] // email addresses
  lastSentAt  DateTime?
  nextSendAt  DateTime?
  isActive    Boolean  @default(true)
  createdById String
  createdBy   User     @relation("CrmScheduledReportCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, nextSendAt])
  @@index([createdById])
}

// --- K6: Web-to-Lead Form ---
model CrmLeadForm {
  id          String   @id @default(cuid())
  name        String
  fields      Json     // array of field definitions
  redirectUrl String?
  notifyEmails String[] @default([])
  assignToId  String?  // auto-assign leads to this user
  tags        String[] @default([])
  isActive    Boolean  @default(true)
  submissions Int      @default(0)
  createdById String
  createdBy   User     @relation("CrmLeadFormCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([assignToId])
  @@index([createdById])
}

// --- 3B.1: Canned Responses / Snippets ---
model CrmSnippet {
  id          String   @id @default(cuid())
  title       String
  content     String
  category    String   @default("general") // general, email, sms, chat
  shortcut    String?  // e.g. /greet, /close
  isActive    Boolean  @default(true)
  createdById String
  createdBy   User     @relation("CrmSnippetCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shortcut])
  @@index([category])
  @@index([isActive])
  @@index([createdById])
}

// --- 3B.3: Quotes/CPQ ---
model CrmQuote {
  id          String         @id @default(cuid())
  number      String         @unique // QUO-001
  dealId      String
  deal        CrmDeal        @relation(fields: [dealId], references: [id])
  status      CrmQuoteStatus @default(DRAFT)
  currency    String         @default("CAD")
  subtotal    Decimal        @default(0) @db.Decimal(12, 2)
  taxRate     Decimal        @default(0) @db.Decimal(5, 4)
  taxAmount   Decimal        @default(0) @db.Decimal(12, 2)
  discount    Decimal        @default(0) @db.Decimal(12, 2)
  total       Decimal        @default(0) @db.Decimal(12, 2)
  validUntil  DateTime?
  sentAt      DateTime?
  viewedAt    DateTime?
  signedAt    DateTime?
  notes       String?
  terms       String?        // terms & conditions
  createdById String
  createdBy   User           @relation("CrmQuoteCreator", fields: [createdById], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  items CrmQuoteItem[]

  @@index([dealId])
  @@index([status])
  @@index([createdById])
  @@index([createdAt])
}

model CrmQuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  quote       CrmQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(10, 2)
  discount    Decimal  @default(0) @db.Decimal(5, 2) // percentage
  total       Decimal  @db.Decimal(10, 2)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([quoteId])
  @@index([productId])
}

// --- 3B.4: Approval Workflows ---
model CrmApproval {
  id            String         @id @default(cuid())
  entityType    String         // 'deal', 'quote', 'discount'
  entityId      String
  reason        String?
  status        ApprovalStatus @default(PENDING)
  requestedById String
  requestedBy   User           @relation("CrmApprovalRequester", fields: [requestedById], references: [id])
  approverId    String?
  approver      User?          @relation("CrmApprovalApprover", fields: [approverId], references: [id])
  approvedAt    DateTime?
  rejectedAt    DateTime?
  rejectionNote String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([entityType, entityId])
  @@index([status])
  @@index([requestedById])
  @@index([approverId])
}

// --- 3E.1: Agent Scheduling ---
model AgentSchedule {
  id        String         @id @default(cuid())
  agentId   String
  agent     User           @relation("AgentScheduleAgent", fields: [agentId], references: [id])
  date      DateTime       @db.Date
  shiftType AgentShiftType @default(MORNING)
  startTime String         // "09:00"
  endTime   String         // "17:00"
  timezone  String         @default("America/Toronto")
  isOff     Boolean        @default(false) // vacation/day off
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([agentId, date])
  @@index([agentId])
  @@index([date])
  @@index([shiftType])
}

// --- 3E.2: QA Scoring Forms ---
model CrmQaForm {
  id          String       @id @default(cuid())
  name        String
  description String?
  criteria    Json         // array of { name, maxScore, weight }
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  scores CrmQaScore[]

  @@index([isActive])
}

model CrmQaScore {
  id         String    @id @default(cuid())
  formId     String
  form       CrmQaForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  agentId    String
  agent      User      @relation("CrmQaScoreAgent", fields: [agentId], references: [id])
  scoredById String
  scoredBy   User      @relation("CrmQaScoredBy", fields: [scoredById], references: [id])
  callLogId  String?
  scores     Json      // { criterionName: score }
  totalScore Decimal   @db.Decimal(5, 2)
  maxScore   Decimal   @db.Decimal(5, 2)
  percentage Decimal   @db.Decimal(5, 2)
  feedback   String?
  createdAt  DateTime  @default(now())

  @@index([formId])
  @@index([agentId])
  @@index([scoredById])
  @@index([callLogId])
  @@index([createdAt])
}

// --- 3E.3: Agent Break Management ---
model AgentBreak {
  id        String         @id @default(cuid())
  agentId   String
  agent     User           @relation("AgentBreakAgent", fields: [agentId], references: [id])
  type      AgentBreakType @default(SHORT_BREAK)
  startedAt DateTime       @default(now())
  endedAt   DateTime?
  duration  Int?           // seconds, computed on end
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([agentId])
  @@index([startedAt])
  @@index([type])
}

// --- 4H.2: Deal Team / Commission Splits (B17) ---
model CrmDealTeam {
  id             String   @id @default(cuid())
  dealId         String?
  userId         String?
  role           String   @default("member") // owner, member, support, overlay
  splitPercent   Decimal  @db.Decimal(5, 2) // commission split %
  isPrimary      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // FIX A1-P0-002: Add @relation directives for FK fields
  deal           CrmDeal? @relation("CrmDealTeamMembers", fields: [dealId], references: [id], onDelete: SetNull)
  user           User?    @relation("UserDealTeams", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([dealId, userId])
  @@index([dealId])
  @@index([userId])
}

model CrmContract {
  id              String         @id @default(cuid())
  title           String
  dealId          String?
  contactId       String?
  companyName     String?
  status          ContractStatus @default(DRAFT)
  startDate       DateTime
  endDate         DateTime
  value           Decimal        @db.Decimal(12, 2)
  currency        String         @default("CAD")
  renewalType     String         @default("manual") // manual, auto, none
  renewalNoticeDays Int          @default(30)
  terms           String?        @db.Text
  signedAt        DateTime?
  signedByName    String?
  documentUrl     String?
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // FIX A1-P0-002: Add @relation directives for FK fields
  deal            CrmDeal?       @relation("CrmDealContracts", fields: [dealId], references: [id], onDelete: SetNull)
  contact         User?          @relation("UserCrmContracts", fields: [contactId], references: [id], onDelete: SetNull)
  createdBy       User?          @relation("UserCreatedCrmContracts", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([dealId])
  @@index([contactId])
  @@index([status])
  @@index([endDate])
  @@index([createdById])
}

model CrmTicket {
  id            String         @id @default(cuid())
  number        String         @unique // TKT-001
  subject       String
  description   String?        @db.Text
  status        TicketStatus   @default(NEW)
  priority      TicketPriority @default(MEDIUM)
  category      TicketCategory @default(GENERAL)
  contactId     String?
  contactName   String?
  contactEmail  String?
  assignedToId  String?
  conversationId String?       // link to InboxConversation
  slaDeadline   DateTime?
  resolvedAt    DateTime?
  closedAt      DateTime?
  firstResponseAt DateTime?
  tags          String[]       @default([])
  metadata      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // FIX A1-P2-003: Add consistent nullable FK relations with proper onDelete
  contact    User?  @relation("CrmTicketContact", fields: [contactId], references: [id], onDelete: SetNull)
  assignedTo User?  @relation("CrmTicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  comments CrmTicketComment[]

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([assignedToId])
  @@index([contactId])
  @@index([conversationId])
  @@index([createdAt])
}

model CrmTicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    CrmTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String?
  authorName String?
  content   String   @db.Text
  isInternal Boolean @default(false) // internal note vs customer-visible
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ticketId])
  @@index([authorId])
  @@index([createdAt])
}

model KBArticle {
  id          String          @id @default(cuid())
  title       String
  slug        String          @unique
  content     String          @db.Text
  excerpt     String?
  categoryId  String?
  category    KBCategory?     @relation(fields: [categoryId], references: [id])
  status      KBArticleStatus @default(DRAFT)
  authorId    String?
  viewCount   Int             @default(0)
  helpfulYes  Int             @default(0)
  helpfulNo   Int             @default(0)
  tags        String[]        @default([])
  isPublic    Boolean         @default(true) // visible on customer portal
  publishedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([categoryId])
  @@index([authorId])
  @@index([status])
  @@index([slug])
  @@index([isPublic])
}

model KBCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  parentId    String?
  parent      KBCategory? @relation("KBCategoryHierarchy", fields: [parentId], references: [id])
  children    KBCategory[] @relation("KBCategoryHierarchy")
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  articles KBArticle[]

  @@index([parentId])
  @@index([slug])
}

// --- 4D.1: Workflow Versioning (I16) ---
model CrmWorkflowVersion {
  id           String       @id @default(cuid())
  workflowId   String?
  version      Int          @default(1)
  triggerType  String
  triggerConfig Json
  steps        Json         // snapshot of all steps at this version
  notes        String?      // changelog note
  createdById  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // FIX A1-P0-002: Add @relation directives for FK fields
  workflow     CrmWorkflow? @relation("CrmWorkflowVersions", fields: [workflowId], references: [id], onDelete: SetNull)
  createdBy    User?        @relation("UserCrmWorkflowVersions", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([workflowId, version])
  @@index([workflowId])
  @@index([createdById])
  @@index([createdAt])
}

model CrmPlaybook {
  id          String         @id @default(cuid())
  name        String
  description String?
  status      PlaybookStatus @default(DRAFT)
  stages      Json           // array of { stageId, guidance, checklist[], resources[] }
  targetPipeline String?     // pipeline ID this playbook is for
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status])
  @@index([targetPipeline])
  @@index([createdById])
  @@index([createdAt])
  @@index([updatedAt])
}

// --- 4I.1: Data Retention Policies (L9) ---
model DataRetentionPolicy {
  id            String   @id @default(cuid())
  name          String
  entityType    String   // lead, deal, activity, recording, ticket
  retentionDays Int      @default(365)
  action        String   @default("delete") // delete, anonymize, archive
  isActive      Boolean  @default(true)
  lastRunAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([entityType])
  @@index([isActive])
}

model ProspectList {
  id               String              @id @default(cuid())
  name             String
  description      String?
  source           ProspectListSource  @default(MANUAL)
  status           ProspectListStatus  @default(DRAFT)

  // Metadata source
  sourceQuery      String?
  sourceUrl        String?

  // Stats (denormalized for perf)
  totalCount       Int                 @default(0)
  validatedCount   Int                 @default(0)
  duplicateCount   Int                 @default(0)
  integratedCount  Int                 @default(0)

  // Attribution
  assignmentMethod LeadAssignmentMethod @default(MANUAL)
  assignmentConfig Json?

  // Relations
  createdById      String
  createdBy        User                @relation("ProspectListCreator", fields: [createdById], references: [id])
  prospects        Prospect[]

  tags             String[]            @default([])
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([status])
  @@index([createdById])
  @@index([createdAt])
}

model Prospect {
  id               String          @id @default(cuid())

  // Contact info
  contactName      String
  companyName      String?
  email            String?
  phone            String?
  website          String?
  address          String?
  city             String?
  province         String?
  postalCode       String?
  country          String?

  // Google Maps specific
  googlePlaceId    String?
  googleRating     Float?
  googleReviewCount Int?
  googleCategory   String?
  latitude         Float?
  longitude        Float?
  openingHours     Json?

  // Business info
  industry         String?
  notes            String?
  customFields     Json?

  // Enrichment fields
  firstName        String?
  lastName         String?
  jobTitle         String?
  linkedinUrl      String?
  companySize      String?          // "1-10", "11-50", "51-200", "201-500", "501-1000", "1000+"
  annualRevenue    String?
  naicsCode        String?
  sicCode          String?
  enrichedAt       DateTime?
  enrichmentSource String?          // "hunter", "website_crawl", "linkedin", "apollo", "manual"
  enrichmentScore  Int?             @default(0) // 0-100 composite score

  // Compliance & consent
  consentDate      DateTime?
  consentChannel   String?          // "web_form", "phone", "email", "import"
  dncChecked       Boolean          @default(false)
  dncStatus        DncStatus        @default(CALLABLE)

  // Status & dedup
  status           ProspectStatus  @default(NEW)
  duplicateOfId    String?
  duplicateOf      Prospect?       @relation("ProspectDuplicates", fields: [duplicateOfId], references: [id])
  duplicates       Prospect[]      @relation("ProspectDuplicates")

  // Integration CRM
  convertedLeadId  String?         @unique
  convertedLead    CrmLead?        @relation("ProspectToLead", fields: [convertedLeadId], references: [id])

  // List membership
  listId           String
  list             ProspectList    @relation(fields: [listId], references: [id], onDelete: Cascade)

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([listId, status])
  @@index([email])
  @@index([phone])
  @@index([googlePlaceId])
  @@index([status])
  @@index([companyName])
  @@index([website])
  @@index([enrichmentScore])
  @@index([dncStatus])
}

