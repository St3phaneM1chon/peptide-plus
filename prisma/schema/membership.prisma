// =============================================================================
// MEMBERSHIP / PAYWALL — Content Gating & Subscription Access
// =============================================================================
// Allows tenants to create membership plans with specific content access rules.
// Members subscribe (optionally via Stripe) and gain access to gated content.

model MembershipPlan {
  id            String   @id @default(cuid())
  tenantId      String?
  name          String
  slug          String
  description   String?
  price         Decimal  @default(0) @db.Decimal(10, 2)
  currency      String   @default("CAD")
  interval      String   @default("monthly") // monthly, yearly, one_time, free
  features      Json     @default("[]")       // ["Feature 1", "Feature 2"]
  contentAccess Json     @default("[]")       // ["blog:*", "article:premium", "page:vip-lounge"]
  maxMembers    Int?                           // null = unlimited
  trialDays     Int      @default(0)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  stripePriceId String?                        // Stripe Price ID for paid plans
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members       Membership[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([isActive, sortOrder])
  @@index([createdAt])
  @@index([updatedAt])
}

model Membership {
  id            String    @id @default(cuid())
  tenantId      String?
  planId        String
  userId        String
  status        String    @default("active") // active, cancelled, expired, paused, trialing
  startDate     DateTime  @default(now())
  endDate       DateTime?
  trialEndsAt   DateTime?
  cancelledAt   DateTime?
  pausedAt      DateTime?
  stripeSubId   String?   // Stripe subscription ID
  metadata      Json?     // extra data (cancellation reason, etc.)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  plan          MembershipPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  user          User           @relation("UserMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, planId])
  @@index([tenantId, status])
  @@index([planId])
  @@index([userId])
  @@index([status])
  @@index([endDate])
  @@index([createdAt])
  @@index([updatedAt])
}
