  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  translations FaqTranslation[]

  @@index([category])
  @@index([isPublished])
  @@index([createdAt])
  @@index([updatedAt])
}

model FaqTranslation {
  id           String             @id @default(cuid())
  faqId        String
  locale       String
  question     String
  answer       String
  createdAt    DateTime           @default(now())
