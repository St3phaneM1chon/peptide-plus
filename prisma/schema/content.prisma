  description     String?
  thumbnailUrl    String?
  speaker         String?
  speakerTitle    String?
  speakerImage    String?
  scheduledAt     DateTime?
  duration        Int?
  category        String?
  tags            String?
  registrationUrl String?
  recordingUrl    String?
