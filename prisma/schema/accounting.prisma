  @@index([createdAt])
  @@index([updatedAt])
}

model RecurringEntryTemplate {
  id           String    @id @default(cuid())
  name         String
  description  String?
  frequency    String // DAILY, WEEKLY, MONTHLY, QUARTERLY, YEARLY
  dayOfMonth   Int? // for MONTHLY
  dayOfWeek    Int? // for WEEKLY (0=Sun, 6=Sat)
  nextRunDate  DateTime
  lastRunDate  DateTime?
  isActive     Boolean   @default(true)
  templateData Json // { lines: [{accountId, debit, credit}], description, type }
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([isActive, nextRunDate])
  @@index([frequency])
  @@index([createdAt])
  @@index([updatedAt])
}

// =============================================
// FIXED ASSETS / IMMOBILISATIONS (CCA)
// =============================================
model FixedAsset {
  id                      String                   @id @default(cuid())
  name                    String
  description             String?
  // Asset details
  assetNumber             String                   @unique // Internal tracking number (e.g. FA-001)
  serialNumber            String?
  location                String?
  // Financial
  acquisitionDate         DateTime
  acquisitionCost         Decimal                  @db.Decimal(12, 2)
  residualValue           Decimal                  @default(0) @db.Decimal(12, 2)
  currentBookValue        Decimal                  @db.Decimal(12, 2) // Updated after each depreciation
  accumulatedDepreciation Decimal                  @default(0) @db.Decimal(12, 2)
  // CCA (Capital Cost Allowance)
  ccaClass                Int // CCA class number (8, 10, 12, 13, 14.1, 50, etc.)
  ccaRate                 Decimal @db.Decimal(5, 4) // F-008: CCA rate (was Float, now Decimal for tax precision)
  depreciationMethod      String                   @default("DECLINING_BALANCE") // DECLINING_BALANCE, STRAIGHT_LINE, LEASE_TERM
  halfYearRuleApplied     Boolean                  @default(true) // Half-year rule for first year
  aiiApplied              Boolean                  @default(false) // Accelerated Investment Incentive (1.5x first year)
  superDeduction          Boolean                  @default(false) // 100% immediate expensing (Budget 2025)
  // GIFI
  gifiCode                String? // GIFI code for this asset category
  // Status
  status                  String                   @default("ACTIVE") // ACTIVE, DISPOSED, FULLY_DEPRECIATED, WRITTEN_OFF
  disposalDate            DateTime?
  disposalProceeds        Decimal?                 @db.Decimal(12, 2)
  disposalGainLoss        Decimal?                 @db.Decimal(12, 2)
  // Linked accounts
  assetAccountId          String // Balance sheet asset account
  depreciationAccountId   String // Accumulated depreciation contra account
  expenseAccountId        String // Depreciation expense account
  assetAccount            ChartOfAccount           @relation("AssetAccount", fields: [assetAccountId], references: [id], onDelete: Restrict)
  depreciationAccount     ChartOfAccount           @relation("DepreciationAccount", fields: [depreciationAccountId], references: [id], onDelete: Restrict)
  expenseAccount          ChartOfAccount           @relation("ExpenseAccount", fields: [expenseAccountId], references: [id], onDelete: Restrict)
  // Metadata
  notes                   String?
  attachments             Json? // Array of file references
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  depreciationEntries     FixedAssetDepreciation[]

  @@index([ccaClass])
  @@index([depreciationAccountId])
  @@index([expenseAccountId])
  @@index([status])
  @@index([assetAccountId])
  @@index([acquisitionDate])
  @@index([createdAt])
  @@index([updatedAt])
}

model FixedAssetDepreciation {
  id             String     @id @default(cuid())
  fixedAssetId   String
  fixedAsset     FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)
  // Period
  fiscalYear     Int // e.g. 2026
  periodStart    DateTime
  periodEnd      DateTime
  // Amounts
  openingUCC     Decimal    @db.Decimal(12, 2) // Undepreciated Capital Cost at start
  ccaClaimed     Decimal    @db.Decimal(12, 2) // CCA claimed this period
  closingUCC     Decimal    @db.Decimal(12, 2) // UCC at end of period
  // Journal entry reference
  journalEntryId String?
  // Metadata
  notes          String?
  createdAt      DateTime   @default(now())

  @@unique([fixedAssetId, fiscalYear])
  @@index([fiscalYear])
  @@index([journalEntryId])
  @@index([createdAt])
}

// =============================================
// FISCAL CALENDAR / CALENDRIER FISCAL
// =============================================
model FiscalCalendarEvent {
  id            String    @id @default(cuid())
  // Event details
  title         String
  titleFr       String?
  description   String?
  descriptionFr String?
  // Scheduling
  dueDate       DateTime
  reminderDate  DateTime? // When to send reminder
  // Classification
  category      String // payroll, corporate_tax, sales_tax, information_return, installment
  authority     String // CRA, RQ, BOTH, SERVICE_CANADA
  frequency     String // once, monthly, quarterly, annual
  // Status
  status        String    @default("PENDING") // PENDING, COMPLETED, OVERDUE, SKIPPED
  completedAt   DateTime?
  completedBy   String?
  // Amount (for installments/remittances)
  amount        Decimal?  @db.Decimal(12, 2)
  // Recurrence (for auto-generated events)
  isRecurring   Boolean   @default(false)
  templateId    String? // Reference to the deadline template
  // Metadata
  notes         String?
  attachments   Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([dueDate])
  @@index([status])
  @@index([category])
  @@index([authority])
  @@index([templateId])
  @@index([createdAt])
  @@index([updatedAt])
}

// =============================================
// BANK RULES (auto-categorization)
// =============================================
model BankRule {
  id       String  @id @default(cuid())
  name     String
  priority Int     @default(0)
  isActive Boolean @default(true)

  // Conditions (all optional - multiple conditions = AND logic)
  descriptionContains   String?
  descriptionStartsWith String?
  descriptionExact      String?
  amountMin             Decimal? @db.Decimal(12, 2)
  amountMax             Decimal? @db.Decimal(12, 2)
  amountExact           Decimal? @db.Decimal(12, 2)
  transactionType       String? // DEBIT, CREDIT

  // Actions
  accountId   String?
  account     ChartOfAccount? @relation("bankRuleAccount", fields: [accountId], references: [id])
  categoryTag String?
  taxCode     String? // GST, QST, HST, EXEMPT, ZERO_RATED
  description String? // Override description

  // Stats
  timesApplied  Int       @default(0)
  lastAppliedAt DateTime?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, priority])
  @@index([accountId])
  @@index([createdAt])
  @@index([updatedAt])
}

// =============================================
// ACCOUNTING EXPORT
// =============================================
model AccountingExport {
  id          String   @id @default(cuid())
  name        String
  format      String   @default("CSV") // CSV, PDF, QBO, SAGE
  periodStart DateTime
  periodEnd   DateTime
  filters     String?  // JSON: { accountIds, types, statuses }
  fileUrl     String?
  fileSize    Int?
  status      String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  errorMsg    String?
  createdBy   String
  createdAt   DateTime @default(now())
  completedAt DateTime?

  @@index([status])
  @@index([createdBy])
  @@index([createdAt])
}

// =============================================
// OCR SCAN / DOCUMENT SCANNING
// =============================================
model OcrScan {
  id             String   @id @default(cuid())
  originalUrl    String
  originalName   String
  mimeType       String
  status         String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  extractedText  String?
  extractedData  String?  // JSON: { vendor, date, total, taxAmount, currency, lineItems }
  confidence     Float?
  journalEntryId String?
  errorMsg       String?
  createdBy      String
  createdAt      DateTime @default(now())
  processedAt    DateTime?

  @@index([status])
  @@index([createdBy])
  @@index([journalEntryId])
  @@index([createdAt])
}

// DB-007: Custom Reports Builder
model CustomReport {
  id          String    @id @default(cuid())
  name        String
  description String?
  type        String    // INCOME_STATEMENT, BALANCE_SHEET, CASH_FLOW, AR_AGING, AP_AGING, TAX_SUMMARY, JOURNAL_DETAIL, TRIAL_BALANCE, CUSTOM
  config      String    @db.Text // JSON report configuration (columns, filters, grouping, sorting)
  isTemplate  Boolean   @default(false)
  isPublic    Boolean   @default(false) // Visible to all admins
  createdBy   String?
  schedule    String?   // Cron expression for automated delivery (null = manual only)
  recipients  String?   // JSON array of email addresses for scheduled delivery
  lastRunAt   DateTime?
  lastRunData String?   @db.Text // Cached last run results (JSON)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([type])
  @@index([createdBy])
  @@index([isTemplate])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([updatedAt])
}

// DB-010: Cash flow tracking
model CashFlowEntry {
  id          String   @id @default(cuid())
  type        String   // INFLOW, OUTFLOW
  category    String   // SALES, REFUND, SUBSCRIPTION, PAYROLL, SUPPLIER, TAX, etc.
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("CAD")
  description String?
  reference   String?  // Order ID, invoice number, etc.
  date        DateTime
  isProjected Boolean  @default(false) // true = forecast, false = actual
  recurring   Boolean  @default(false)
  recurFreq   String?  // DAILY, WEEKLY, MONTHLY, QUARTERLY, YEARLY
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([category])
  @@index([date])
  @@index([isProjected])
  @@index([type, date])
  @@index([createdAt])
  @@index([updatedAt])
}

// =============================================
// Payroll Module - Canadian Payroll (Quebec-based)
// =============================================
model Employee {
  id                 String    @id @default(cuid())
  userId             String?   // Optional link to User table (not all employees are system users)
  firstName          String
  lastName           String
  email              String
  sin                String?   // Social Insurance Number (encrypted at rest)
  dateOfBirth        DateTime?
  hireDate           DateTime
  terminationDate    DateTime?
  employmentType     String    @default("FULL_TIME") // FULL_TIME, PART_TIME, CONTRACT, SEASONAL
  province           String    @default("QC") // Province code for tax
  country            String    @default("CA") // CA or US
  annualSalary       Decimal?  @db.Decimal(12, 2)
  hourlyRate         Decimal?  @db.Decimal(8, 2)
  payFrequency       String    @default("BIWEEKLY") // WEEKLY, BIWEEKLY, SEMI_MONTHLY, MONTHLY
  bankTransitNumber  String?
  bankInstitution    String?
  bankAccountNumber  String?
  federalTdCredit    Decimal   @default(0) @db.Decimal(12, 2) // TD1 federal claim
  provincialTdCredit Decimal   @default(0) @db.Decimal(12, 2) // TP-1015.3-V QC
  vacationPayRate    Decimal   @default(4) @db.Decimal(5, 2) // % (4% minimum QC/CA)
  status             String    @default("ACTIVE") // ACTIVE, ON_LEAVE, TERMINATED
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  payrollEntries PayrollEntry[]
  payStubs       PayStub[]

  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([deletedAt])
}

model PayrollRun {
  id                String    @id @default(cuid())
  runDate           DateTime
  periodStart       DateTime
  periodEnd         DateTime
  payDate           DateTime
  status            String    @default("DRAFT") // DRAFT, CALCULATED, APPROVED, PAID, VOID
  totalGross        Decimal   @default(0) @db.Decimal(12, 2)
  totalDeductions   Decimal   @default(0) @db.Decimal(12, 2)
  totalNet          Decimal   @default(0) @db.Decimal(12, 2)
  totalEmployerCost Decimal   @default(0) @db.Decimal(12, 2)
  journalEntryId    String?   // Link to posted journal entry
  approvedBy        String?
  approvedAt        DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  entries PayrollEntry[]

  @@index([status])
  @@index([periodStart, periodEnd])
  @@index([deletedAt])
  @@index([journalEntryId])
}

model PayrollEntry {
  id             String  @id @default(cuid())
  payrollRunId   String
  employeeId     String
  hoursWorked    Decimal @default(0) @db.Decimal(8, 2)
  overtimeHours  Decimal @default(0) @db.Decimal(8, 2)
  grossPay       Decimal @default(0) @db.Decimal(12, 2)

  // Canadian deductions
  cppContribution Decimal @default(0) @db.Decimal(10, 2) // CPP/QPP
  eiPremium       Decimal @default(0) @db.Decimal(10, 2) // EI premium
  federalTax      Decimal @default(0) @db.Decimal(10, 2)
  provincialTax   Decimal @default(0) @db.Decimal(10, 2)
  qpipPremium     Decimal @default(0) @db.Decimal(10, 2) // QPIP (Quebec Parental Insurance)

  // Employer contributions
  employerCpp  Decimal @default(0) @db.Decimal(10, 2)
  employerEi   Decimal @default(0) @db.Decimal(10, 2)
  employerQpip Decimal @default(0) @db.Decimal(10, 2)
  employerHst  Decimal @default(0) @db.Decimal(10, 2) // Health Services Fund (QC)
  employerWcb  Decimal @default(0) @db.Decimal(10, 2) // CNESST (QC WCB)

  // Other deductions/benefits
  vacationPay        Decimal @default(0) @db.Decimal(10, 2)
  otherDeductions    Decimal @default(0) @db.Decimal(10, 2)
  otherBenefits      Decimal @default(0) @db.Decimal(10, 2)
  otherDeductionsDesc String?
  otherBenefitsDesc   String?

  totalDeductions   Decimal @default(0) @db.Decimal(12, 2)
  netPay            Decimal @default(0) @db.Decimal(12, 2)
  totalEmployerCost Decimal @default(0) @db.Decimal(12, 2)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id])
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@index([payrollRunId])
  @@index([employeeId])
}

model PayStub {
  id               String   @id @default(cuid())
  employeeId       String
  periodStart      DateTime
  periodEnd        DateTime
  payDate          DateTime
  grossPay         Decimal  @db.Decimal(12, 2)
  totalDeductions  Decimal  @db.Decimal(12, 2)
  netPay           Decimal  @db.Decimal(12, 2)
  ytdGross         Decimal  @default(0) @db.Decimal(12, 2)
  ytdDeductions    Decimal  @default(0) @db.Decimal(12, 2)
  ytdNet           Decimal  @default(0) @db.Decimal(12, 2)
  deductionDetails Json     // Detailed breakdown JSON
  pdfUrl           String?  // Generated PDF URL
  createdAt        DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([periodStart, periodEnd])
}

// =============================================================================
// Time Tracking (Roadmap 3-3)
// =============================================================================
model TimeEntry {
  id             String    @id @default(cuid())
  employeeId     String?
  userId         String?
  userName       String
  date           DateTime  @default(now())
  startTime      DateTime?
  endTime        DateTime?
  hoursWorked    Decimal   @db.Decimal(6, 2)
  description    String?
  projectId      String?
  projectName    String?
  taskCategory   String?
  isBillable     Boolean   @default(false)
  billableRate   Decimal?  @db.Decimal(8, 2)
  status         String    @default("DRAFT")
  approvedBy     String?
  approvedAt     DateTime?
  rejectedReason String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@index([employeeId])
  @@index([userId])
  @@index([date])
  @@index([status])
  @@index([projectId])
  @@index([projectName])
  @@index([deletedAt])
}

model TimeProject {
  id           String    @id @default(cuid())
  name         String
  code         String    @unique
  description  String?
  clientName   String?
  budget       Decimal?  @db.Decimal(12, 2)
  budgetAmount Decimal?  @db.Decimal(12, 2)
  defaultRate  Decimal?  @db.Decimal(8, 2)
  status       String    @default("ACTIVE")
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@index([code])
  @@index([status])
  @@index([deletedAt])
}

model BatchJob {
  id             String    @id @default(cuid())
  type           String // BATCH_JOURNAL_ENTRIES, BATCH_INVOICES, BATCH_PAYMENTS, BATCH_EXPENSES, BATCH_STATUS_UPDATE, BATCH_EXPORT, BATCH_DELETE
  status         String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED, CANCELLED
  totalItems     Int       @default(0)
  processedItems Int       @default(0)
  successItems   Int       @default(0)
  failedItems    Int       @default(0)
  inputData      String?   @db.Text // JSON input payload
  resultData     String?   @db.Text // JSON results
  errorLog       String?   @db.Text // JSON error details
  createdBy      String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
}

// =============================================================================
// Project / Job Costing (Roadmap 3-4)
// =============================================================================
model CostProject {
  id             String    @id @default(cuid())
  name           String
  code           String    @unique
  description    String?
  clientName     String?
  clientEmail    String?
  projectManager String? // User ID
  status         String    @default("ACTIVE") // ACTIVE, COMPLETED, ON_HOLD, CANCELLED
  startDate      DateTime?
  endDate        DateTime?
  budgetHours    Decimal?  @db.Decimal(10, 2)
  budgetAmount   Decimal?  @db.Decimal(12, 2)
  billingMethod  String    @default("FIXED") // FIXED, TIME_AND_MATERIALS, RETAINER
  fixedPrice     Decimal?  @db.Decimal(12, 2)
  retainerAmount Decimal?  @db.Decimal(12, 2)
  retainerPeriod String? // MONTHLY, QUARTERLY
  defaultRate    Decimal?  @db.Decimal(8, 2)
  notes          String?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  costEntries ProjectCostEntry[]
  milestones  ProjectMilestone[]

  @@index([code])
  @@index([status])
  @@index([clientName])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([updatedAt])
}

model ProjectCostEntry {
  id             String   @id @default(cuid())
  projectId      String
  type           String // LABOR, EXPENSE, MATERIAL, SUBCONTRACTOR, OVERHEAD
  description    String
  date           DateTime @default(now())
  quantity       Decimal  @default(1) @db.Decimal(10, 2)
  unitCost       Decimal  @db.Decimal(12, 2)
  totalCost      Decimal  @db.Decimal(12, 2)
  billableAmount Decimal  @default(0) @db.Decimal(12, 2)
  isBillable     Boolean  @default(true)
  employeeId     String?
  employeeName   String?
  timeEntryId    String? // Link to TimeEntry
  expenseId      String? // Link to Expense
  invoiceId      String? // Link to CustomerInvoice when billed
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project CostProject @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([type])
  @@index([date])
  @@index([employeeId])
  @@index([timeEntryId])
  @@index([expenseId])
  @@index([invoiceId])
  @@index([createdAt])
  @@index([updatedAt])
}

model ProjectMilestone {
  id          String    @id @default(cuid())
  projectId   String
  name        String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  amount      Decimal?  @db.Decimal(12, 2) // Billing amount for this milestone
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project CostProject @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
}

// =============================================================================
// Client Portal Access (token-based public access to accounting data)
// =============================================================================
model ClientPortalAccess {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  email       String
  clientName  String
  companyName String?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  lastAccess  DateTime?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([token])
  @@index([email])
  @@index([isActive])
}

// =============================================================================
// Multi-Entity / Multi-Company (Roadmap 4-6)
// =============================================================================
model LegalEntity {
  id              String    @id @default(cuid())
  name            String
  code            String    @unique
  legalName       String?
  taxNumber       String?
  gstNumber       String?
  qstNumber       String?
  address         String?
  city            String?
  province        String?
  postalCode      String?
  country         String    @default("CA")
  currency        String    @default("CAD")
  fiscalYearStart Int       @default(1)
  parentEntityId  String?
  isActive        Boolean   @default(true)
  isDefault       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  parentEntity        LegalEntity?              @relation("EntityHierarchy", fields: [parentEntityId], references: [id])
  childEntities       LegalEntity[]             @relation("EntityHierarchy")
  intercoTransactions IntercompanyTransaction[] @relation("IntercoFrom")
  intercoReceived     IntercompanyTransaction[] @relation("IntercoTo")

  @@index([code])
  @@index([parentEntityId])
  @@index([isActive])
}

model IntercompanyTransaction {
  id                String    @id @default(cuid())
  transactionNumber String    @unique
  fromEntityId      String
  toEntityId        String
  type              String
  description       String
  amount            Decimal   @db.Decimal(14, 2)
  currency          String    @default("CAD")
  status            String    @default("PENDING")
  journalEntryRef   String?
  matchingRef       String?
  eliminatedAt      DateTime?
  createdBy         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  fromEntity LegalEntity @relation("IntercoFrom", fields: [fromEntityId], references: [id])
  toEntity   LegalEntity @relation("IntercoTo", fields: [toEntityId], references: [id])

  @@index([fromEntityId])
  @@index([toEntityId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model RSDeProject {
  id                         String            @id @default(cuid())
  name                       String
  description                String?           @db.Text
  fiscalYear                 Int
  startDate                  DateTime?
  endDate                    DateTime?
  status                     RSDeProjectStatus @default(DRAFT)
  technologicalUncertainty   String?           @db.Text
  technologicalAdvancement   String?           @db.Text
  systematicInvestigation    String?           @db.Text
  isSpcc                     Boolean           @default(true)
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt

  expenses     RSDeExpense[]
  calculations RSDeCalculation[]

  @@index([fiscalYear])
  @@index([status])
}

model RSDeExpense {
  id               String              @id @default(cuid())
  projectId        String
  category         RSDeExpenseCategory
  description      String
  amount           Decimal             @db.Decimal(12, 2)
  date             DateTime
  employeeName     String?
  hoursWorked      Decimal?            @db.Decimal(8, 2)
  hourlyRate       Decimal?            @db.Decimal(8, 2)
  isEligible       Boolean             @default(true)
  eligibilityNotes String?
  createdAt        DateTime            @default(now())

  project RSDeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([category])
  @@index([date])
}

model RSDeCalculation {
  id              String   @id @default(cuid())
  projectId       String
  fiscalYear      Int
  totalEligible   Decimal  @db.Decimal(14, 2)
  federalRate     Decimal  @db.Decimal(5, 4)
  federalCredit   Decimal  @db.Decimal(14, 2)
  provincialRate  Decimal  @db.Decimal(5, 4)
  provincialCredit Decimal @db.Decimal(14, 2)
  totalCredit     Decimal  @db.Decimal(14, 2)
  spccLimit       Decimal  @db.Decimal(14, 2)
  isRefundable    Boolean  @default(true)
  calculatedAt    DateTime @default(now())

  project RSDeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([fiscalYear])
}

// --- 3B.5: Multi-Currency Exchange Rates ---
model ExchangeRate {
  id           String   @id @default(cuid())
  fromCurrency String
  toCurrency   String
  rate         Decimal  @db.Decimal(12, 6)
  source       String   @default("manual") // manual, api
  fetchedAt    DateTime @default(now())
  createdAt    DateTime @default(now())

  @@unique([fromCurrency, toCurrency])
  @@index([fromCurrency])
  @@index([toCurrency])
}

